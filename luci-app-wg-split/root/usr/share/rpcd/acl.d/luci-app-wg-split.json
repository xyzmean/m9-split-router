{
	"luci-app-wg-split": {
		"description": "Grant access to wg-split configuration",
		"read": {
			"uci": [ "wg-split", "network" ],
			"ubus": {
				"network.interface": [ "dump" ],
				"network": [ "get_proto_handlers" ],
				"file": [ "exec" ]
			},
			"file": {
				"/usr/local/sbin/wg-split-status": [ "exec" ],
				"/etc/init.d/wg-split": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "wg-split" ]
		}
	}
}
