{
	"luci-app-wg-split": {
		"description": "Grant access to wg-split status, diagnostics and maintenance actions",
		"read": {
			"uci": [ "wg-split", "network" ],
			"ubus": {
				"network.interface": [ "dump" ],
				"network": [ "get_proto_handlers" ],
				"wg-split": [ "status", "events" ]
			}
		},
		"write": {
			"uci": [ "wg-split" ],
			"ubus": {
				"wg-split": [ "action" ]
			}
		}
	}
}
