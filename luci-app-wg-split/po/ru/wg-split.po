msgid "Disable split routing now? All LAN traffic will exit via WAN until the service re-enables it (or you stop it)."
msgstr "Отключить split-маршрутизацию сейчас? Весь трафик LAN пойдёт через WAN, пока служба не включит её снова (или пока вы её не остановите)."

msgid "Split routing disabled"
msgstr "Split-маршрутизация отключена"

msgid "Status & diagnostics"
msgstr "Статус и диагностика"

msgid "wg-split"
msgstr "wg-split"

msgid "Local split-tunnel: policy-route LAN traffic over priority-ordered WireGuard/AmneziaWG tunnels, with downloaded IP/domain lists and optional zapret DPI-bypass. Create the tunnel interfaces normally under Network → Interfaces, then list them below by priority."
msgstr "Локальный split-туннель: маршрутизация трафика LAN по приоритетным туннелям WireGuard/AmneziaWG, со скачиваемыми списками IP/доменов и опциональным обходом DPI через zapret. Создайте интерфейсы туннелей обычным образом в Network → Interfaces, затем перечислите их ниже по приоритету."

msgid "General"
msgstr "Общие"

msgid "Routing mode"
msgstr "Режим маршрутизации"

msgid "blocklist — only listed/ipsum IPs ride the VPN"
msgstr "blocklist — через VPN идут только IP из списков/ipsum"

msgid "full — default via VPN, direct list = exceptions"
msgstr "full — по умолчанию через VPN, список direct = исключения"

msgid "split — only explicit VPN lists ride the VPN"
msgstr "split — через VPN идут только явные VPN-списки"

msgid "Failover interval"
msgstr "Интервал отказоустойчивости"

msgid "Seconds between health/failover checks."
msgstr "Секунды между проверками здоровья/отказоустойчивости."

msgid "Kill switch"
msgstr "Аварийная блокировка"

msgid "Drop policy-VPN traffic when every tunnel is down instead of leaking to WAN."
msgstr "Сбрасывать VPN-трафик политики, когда все туннели недоступны, вместо утечки в WAN."

msgid "LAN interface"
msgstr "Интерфейс LAN"

msgid "LAN subnet (CIDR)"
msgstr "Подсеть LAN (CIDR)"

msgid "Health ping targets"
msgstr "Цели health-ping"

msgid "Pinged through each tunnel to test it (any reply = healthy)."
msgstr "Пингуются через каждый туннель для проверки (любой ответ = здоров)."

msgid "WAN health URL"
msgstr "URL проверки WAN"

msgid "curled over WAN to decide the zapret vs plain-WAN fallback rung."
msgstr "Запрашивается через WAN (curl) для выбора между zapret и обычным WAN-резервом."

msgid "Enable ipsum (VPN IP list)"
msgstr "Включить ipsum (список VPN-IP)"

msgid "ipsum list URL"
msgstr "URL списка ipsum"

msgid "Enable ru/cn direct list"
msgstr "Включить direct-список ru/cn"

msgid "ru/cn list URL"
msgstr "URL списка ru/cn"

msgid "VPN domains list URL"
msgstr "URL списка VPN-доменов"

msgid "Downloaded domains tagged to the VPN at dnsmasq resolve time."
msgstr "Скачанные домены помечаются в VPN на этапе разрешения dnsmasq."

msgid "Ignore/direct domains list URL"
msgstr "URL списка игнор/direct-доменов"

msgid "Use zapret DPI-bypass"
msgstr "Использовать обход DPI zapret"

msgid "Auto-skipped if zapret is not installed."
msgstr "Автоматически пропускается, если zapret не установлен."

msgid "Manual entries"
msgstr "Ручные записи"

msgid "VPN subnets"
msgstr "VPN-подсети"

msgid "Direct subnets"
msgstr "Direct-подсети"

msgid "VPN domains"
msgstr "VPN-домены"

msgid "Direct domains"
msgstr "Direct-домены"

msgid "Lowest priority number wins. Pick interfaces you created under Network → Interfaces."
msgstr "Меньший номер приоритета побеждает. Выбирайте интерфейсы, созданные в Network → Interfaces."

msgid "Interface"
msgstr "Интерфейс"

msgid "(no wireguard/amneziawg interfaces found)"
msgstr "(интерфейсы wireguard/amneziawg не найдены)"

msgid "Priority"
msgstr "Приоритет"

msgid "Per-device overrides"
msgstr "Переопределения по устройствам"

msgid "Pin a LAN host to vpn or direct by its IP."
msgstr "Закрепить LAN-хост за vpn или direct по его IP."

msgid "Device IP"
msgstr "IP устройства"

msgid "Route via"
msgstr "Маршрут через"

msgid "VPN"
msgstr "VPN"

msgid "Direct"
msgstr "Direct"

