#!/bin/sh
# wg-split-watchdog — every 3 min via cron, and once after each wg-split-apply.
#   VPN healthy : install ip rules + default route (table 200) + DoH pins, self-heal ipsum/zapret.
#   VPN down    : KILLSWITCH=1 -> blackhole table 200 (drop policy traffic, no WAN leak);
#                 KILLSWITCH=0 -> WAN-only fallback (rules removed).
set -u
. /usr/local/lib/wg-split/common.sh

probe_ping() {
    _ok=0
    for _t in $HEALTH_PING_TARGETS; do
        if ping -I "$VPN_IFACE" -c "$HEALTH_PING_COUNT" -W "$HEALTH_PING_TIMEOUT" -q "$_t" >/dev/null 2>&1; then
            _ok=$((_ok + 1)); [ "$_ok" -ge "$HEALTH_PING_SUCCESS_REQUIRED" ] && return 0
        fi
    done
    return 1
}
probe_curl() {
    curl --interface "$VPN_IFACE" --max-time "$HEALTH_CURL_TIMEOUT" -fsS \
        -o /dev/null "$HEALTH_CURL_URL" >/dev/null 2>&1
}
vpn_healthy() {
    ip link show dev "$VPN_IFACE" >/dev/null 2>&1 || return 1
    case "$HEALTH_METHOD" in
        ping) probe_ping ;; curl) probe_curl ;;
        *) die "unknown HEALTH_METHOD=$HEALTH_METHOD" ;;
    esac
}

ensure_ipsum() {
    [ "${IPSUM_ENABLED:-1}" = "1" ] || return 0
    [ -s "$IPSUM_NFT_FILE" ] || { warn "ipsum nft file missing: $IPSUM_NFT_FILE"; return 1; }
    _cnt=$(set_count "$IPSUM_TABLE" "$IPSUM_SET")
    [ "${_cnt:-0}" -ge "$IPSUM_MIN_COUNT" ] && return 0
    log "ipsum set has $_cnt (<$IPSUM_MIN_COUNT), reloading"
    nft -f "$IPSUM_NFT_FILE" 2>/tmp/wg-split-ipsum-reload.err && return 0
    warn "ipsum reload failed: $(head -3 /tmp/wg-split-ipsum-reload.err)"; return 1
}

ensure_zapret() {
    [ "${ZAPRET_ENABLED:-1}" = "1" ] || return 0
    [ -x "$ZAPRET_INIT" ] || return 0
    "$ZAPRET_INIT" enabled >/dev/null 2>&1 || "$ZAPRET_INIT" enable >/dev/null 2>&1 || true
    _need_sync=0
    if ! (ps w 2>/dev/null || ps 2>/dev/null) | grep -q '[n]fqws'; then
        "$ZAPRET_INIT" start >/dev/null 2>&1 || true; _need_sync=1
    else
        _noz=$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")
        [ "${_noz:-0}" -lt "$ZAPRET_NOZAPRET_MIN" ] && _need_sync=1
    fi
    [ "$_need_sync" = 1 ] && [ -x /usr/local/sbin/wg-split-sync-nozapret ] \
        && /usr/local/sbin/wg-split-sync-nozapret >/dev/null 2>&1 || true
}

common_rules() {   # the two ip rules are mode-independent; routes differ below
    ensure_rule "$ANTI_LOOP_PRIO" "fwmark $ANTI_LOOP_MARK/$ANTI_LOOP_MASK lookup main" \
        ip -4 rule add fwmark "$ANTI_LOOP_MARK/$ANTI_LOOP_MASK" table main priority "$ANTI_LOOP_PRIO"
    ensure_rule "$WG_RULE_PRIO" "fwmark $WG_MARK/$WG_MARK_MASK lookup $WG_TABLE" \
        ip -4 rule add fwmark "$WG_MARK/$WG_MARK_MASK" table "$WG_TABLE" priority "$WG_RULE_PRIO"
}

set_vpn() {
    common_rules
    ip -4 route replace default dev "$VPN_IFACE" table "$WG_TABLE"
    # mesh return path: the tunnel address is a /32 (dashboard configs), so the
    # kernel creates no on-link route — without this, traffic FROM the mesh
    # (dashboard ssh/ping, other nodes) gets answered out the WAN and dies.
    ip -4 route replace "$MESH_CIDR" dev "$VPN_IFACE" ${WG_SRC_IP:+src "$WG_SRC_IP"} 2>/dev/null || true
    for _ip in $DOH_IPS; do pin_route "$_ip" "$VPN_IFACE" "$WG_SRC_IP"; done
    if ensure_ipsum; then :
    elif [ "$IPSUM_FALLBACK_SKIP" = "1" ]; then
        warn "ipsum unavailable — rules in place but set empty"
    else die "ipsum unavailable and IPSUM_FALLBACK_SKIP=0"; fi
    ensure_zapret
    write_state "vpn:$VPN_IFACE"; fail_reset
}

set_down() {
    if [ "${KILLSWITCH:-0}" = "1" ]; then
        # keep the WG rule, but blackhole table 200 → policy-VPN traffic is dropped
        # (no WAN leak); unmarked WAN traffic is unaffected.
        common_rules
        ip -4 route replace blackhole default table "$WG_TABLE"
        for _ip in $DOH_IPS; do ip -4 route del "$_ip" dev "$VPN_IFACE" >/dev/null 2>&1 || true; done
        write_state "killswitch"
    else
        ensure_rule "$ANTI_LOOP_PRIO" "fwmark $ANTI_LOOP_MARK/$ANTI_LOOP_MASK lookup main" \
            ip -4 rule add fwmark "$ANTI_LOOP_MARK/$ANTI_LOOP_MASK" table main priority "$ANTI_LOOP_PRIO"
        delete_rule_prio "$WG_RULE_PRIO"
        ip -4 route flush table "$WG_TABLE" >/dev/null 2>&1 || true
        for _ip in $DOH_IPS; do ip -4 route del "$_ip" dev "$VPN_IFACE" >/dev/null 2>&1 || true; done
        write_state "wan"
    fi
    ensure_zapret
}

_old=$(read_state)
if vpn_healthy; then
    set_vpn
    [ "$_old" = "vpn:$VPN_IFACE" ] || log "VPN healthy via $VPN_IFACE — split active (mode ${MODE:-blocklist})"
else
    # Fail CLOSED first when the killswitch is on. The AUTO re-probe below bounces
    # the tunnel per candidate and can take many seconds; during that window table
    # 200 has no usable route, so marked policy-VPN traffic would fall through to
    # the main table and leak out the WAN. Install the blackhole NOW (set_down)
    # before any probing, so there is no fail-open window — set_vpn() lifts it on
    # recovery. Non-killswitch keeps WAN-fallback semantics, so nothing to do early.
    if [ "${KILLSWITCH:-0}" = "1" ]; then
        set_down
    fi
    # AUTO endpoint: the tunnel is down — re-probe candidates and switch to the
    # best working one (relay last). Only if that fails do we fall back to WAN.
    if [ "${AUTO_ENDPOINT:-0}" = "1" ] && [ -x /usr/local/sbin/wg-split-endpoint ]; then
        log "VPN $VPN_IFACE down — re-selecting endpoint (auto)"
        /usr/local/sbin/wg-split-endpoint --auto >/dev/null 2>&1 || true
        if vpn_healthy; then
            set_vpn; log "VPN recovered via re-selected endpoint — split active"
            return 0 2>/dev/null || exit 0
        fi
    fi
    _n=$(fail_inc); set_down
    if [ "${KILLSWITCH:-0}" = "1" ]; then
        [ "$_old" = "killswitch" ] || log "VPN $VPN_IFACE down (fail #$_n) — KILLSWITCH: policy traffic dropped"
    else
        [ "$_old" = "wan" ] || log "VPN $VPN_IFACE down (fail #$_n) — fallback to WAN-only"
    fi
    if [ "$PEER_FAILOVER_ENABLED" = "1" ] && [ "$_n" -ge "$PEER_FAILOVER_THRESHOLD" ] \
       && [ -x /usr/local/sbin/wg-split-failover ]; then
        log "failover threshold hit — invoking wg-split-failover"
        /usr/local/sbin/wg-split-failover >/dev/null 2>&1 || true
    fi
fi
