#!/bin/sh
# m9-rtr-agent — keeps this router's split policy in sync with the M9 dashboard.
#
# Every AGENT_INTERVAL it POSTs a status report to $DASHBOARD_URL/api/rtr/sync
# (auth: X-Router-Token) and receives the current policy + entry-point endpoints.
# When the policy rev moves, it persists the response to $POLICY_JSON and runs
# wg-split-apply, which regenerates the nft/dnsmasq layer and routing.
#
# Pure busybox: curl + jsonfilter. Runs under procd (see /etc/init.d/m9-rtr-agent).
set -u
. /usr/local/lib/wg-split/common.sh

[ -n "${DASHBOARD_URL:-}" ] || die "DASHBOARD_URL not set in $CONF_FILE"
[ -n "${ROUTER_TOKEN:-}" ]  || die "ROUTER_TOKEN not set in $CONF_FILE"
INTERVAL="${AGENT_INTERVAL:-30}"
INSECURE=""; [ "${AGENT_TLS_INSECURE:-0}" = "1" ] && INSECURE="-k"
SYNC_URL="${DASHBOARD_URL%/}/api/rtr/sync"
RESP="/tmp/m9-rtr-sync.json"

applied_rev() { [ -r "$POLICY_ENV" ] && . "$POLICY_ENV"; echo "${APPLIED_REV:-0}"; }

# JSON array of current LAN devices from the DHCP lease file: ip/mac/host.
devices_json() {
    _f=/tmp/dhcp.leases
    [ -r "$_f" ] || { echo "[]"; return; }
    awk '{ printf "%s{\"ip\":\"%s\",\"mac\":\"%s\",\"host\":\"%s\"}",
                  (NR>1?",":""), $3, $2, ($4=="*"?"":$4) }
         END { print "" }' "$_f" 2>/dev/null | sed 's/^/[/; s/$/]/'
}

json_bool() { [ "${1:-0}" = "1" ] && echo true || echo false; }

list_count() {
    [ -r "$1" ] || { echo 0; return; }
    awk '
        /^[[:space:]]*($|#)/ { next }
        { n++ }
        END { print n + 0 }
    ' "$1" 2>/dev/null || echo 0
}

mem_kb() {
    awk -v k="$1:" '$1 == k { print $2; found = 1; exit } END { if (!found) print 0 }' \
        /proc/meminfo 2>/dev/null
}

zapret_available() {
    [ -n "${ZAPRET_INIT:-}" ] && [ -x "$ZAPRET_INIT" ] && return 0
    [ -x /opt/zapret/nfq/nfqws ] && return 0
    command -v nfqws >/dev/null 2>&1 && return 0
    zapret_running && return 0
    return 1
}

zapret_running() {
    (ps w 2>/dev/null || ps 2>/dev/null) | grep -q '[n]fqws'
}

build_status() {
    _ver="$(cat /etc/wg-split/VERSION 2>/dev/null || echo dev)"
    _up="$(cut -d. -f1 /proc/uptime 2>/dev/null || echo 0)"
    _wan="$(ip -4 -o addr show 2>/dev/null | awk '/ wan@| wan /{print $4}' | cut -d/ -f1 | head -1)"
    _hsage="$(wg_handshake_age)"
    _rx="$(wgshow "$VPN_IFACE" transfer | awk 'NR==1{print $2}')"; _rx="${_rx:-0}"
    _tx="$(wgshow "$VPN_IFACE" transfer | awk 'NR==1{print $3}')"; _tx="${_tx:-0}"
    _err=""; [ "$(read_state)" = "wan" ] && _err="vpn-down-fallback-wan"
    _zap_av=0; zapret_available && _zap_av=1
    _zap_run=0; zapret_running && _zap_run=1
    _ipsum_nft="$(set_count "$IPSUM_TABLE" "$IPSUM_SET")"
    _ru_nft="$(set_count "$RU_TABLE" "$RU_SET")"
    _noz_nft="$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")"
    _ipsum_list="$(list_count "$IPSUM_FILE")"
    _ru_list="$(list_count "$RU_FILE")"
    _mem_total="$(mem_kb MemTotal)"
    _mem_avail="$(mem_kb MemAvailable)"
    printf '{"version":"%s","uptime":%s,"wan_ip":"%s","lan_if":"%s","wg_if":"%s",' \
           "$_ver" "$_up" "${_wan:-}" "$LAN_IFACE" "$VPN_IFACE"
    _entry="$(cat "${CHOSEN_FILE:-/var/run/wg-split-endpoint}" 2>/dev/null)"
    _mtu="$(cat /var/run/wg-split-mtu 2>/dev/null || echo 1280)"
    printf '"applied_rev":%s,"handshake_age":%s,"rx":%s,"tx":%s,"entry":"%s","mtu":%s,"error":"%s",' \
           "$(applied_rev)" "$_hsage" "$_rx" "$_tx" "${_entry:-}" "$_mtu" "$_err"
    printf '"zapret_available":%s,"zapret_enabled":%s,"zapret_running":%s,' \
           "$(json_bool "$_zap_av")" "$(json_bool "${ZAPRET_ENABLED:-0}")" "$(json_bool "$_zap_run")"
    printf '"ipsum_nft_count":%s,"ru_nft_count":%s,"nozapret_nft_count":%s,' \
           "$_ipsum_nft" "$_ru_nft" "$_noz_nft"
    printf '"ipsum_list_count":%s,"ru_list_count":%s,"mem_total_kb":%s,"mem_available_kb":%s,' \
           "$_ipsum_list" "$_ru_list" "$_mem_total" "$_mem_avail"
    printf '"devices":%s}' "$(devices_json)"
}

# Boot-time endpoint autoselect (once): probe candidates and switch to the best.
# Runs from the persisted policy.json even before the dashboard is reachable.
boot_select() {
    [ "${AUTO_ENDPOINT:-0}" = "1" ] || return 0
    [ -x /usr/local/sbin/wg-split-endpoint ] || return 0
    [ -r "$POLICY_JSON" ] || return 0
    log "boot: autoselecting best endpoint (curl probe)"
    /usr/local/sbin/wg-split-endpoint --auto >/dev/null 2>&1 || warn "boot autoselect found no endpoint"
}

sync_once() {
    body="$(build_status)"
    if ! curl $INSECURE -fsS --max-time 20 \
            -H "X-Router-Token: $ROUTER_TOKEN" \
            -H "Content-Type: application/json" \
            -X POST --data "$body" "$SYNC_URL" -o "$RESP" 2>/dev/null; then
        warn "sync failed: unreachable $SYNC_URL"
        return 1
    fi
    [ "$(jsonfilter -i "$RESP" -e '@.ok' 2>/dev/null)" = "true" ] || {
        warn "sync rejected: $(jsonfilter -i "$RESP" -e '@.error' 2>/dev/null || echo '?')"
        return 1
    }
    update_url="$(jsonfilter -i "$RESP" -e '@.update_url' 2>/dev/null || true)"
    if [ -n "$update_url" ]; then
        # only ever execute update scripts served by OUR dashboard; the token
        # also auths the download so a 3rd party can't serve us a payload
        case "$update_url" in
            "${DASHBOARD_URL%/}"/*) ;;
            *) warn "auto-update refused: $update_url not under $DASHBOARD_URL"; update_url="" ;;
        esac
    fi
    if [ -n "$update_url" ]; then
        log "auto-update requested via sync, downloading $update_url"
        if curl $INSECURE -fsSL --max-time 60 -H "X-Router-Token: $ROUTER_TOKEN" \
                -o /tmp/agent-update.sh "$update_url"; then
            # procd respawns us after exit; the update script also restarts the service
            sh /tmp/agent-update.sh >/dev/null 2>&1 &
            exit 0
        else
            warn "auto-update download failed"
        fi
    fi

    new="$(jsonfilter -i "$RESP" -e '@.rev' 2>/dev/null)"; new="${new:-0}"
    cur="$(applied_rev)"
    has_endpoints="$(jsonfilter -i "$POLICY_JSON" -e '@.endpoints[0].name' 2>/dev/null)"
    cur_portal="$(jsonfilter -i "$POLICY_JSON" -e '@.portal_host' 2>/dev/null)"
    new_portal="$(jsonfilter -i "$RESP" -e '@.portal_host' 2>/dev/null)"
    if [ "$new" != "$cur" ] || [ -z "$has_endpoints" ] || [ "$new_portal" != "$cur_portal" ]; then
        log "policy rev $cur -> $new (or endpoints/portal changed); applying"
        cp "$RESP" "$POLICY_JSON"
        /usr/local/sbin/wg-split-apply >/dev/null 2>&1 \
            && log "policy rev $new applied" \
            || warn "wg-split-apply failed for rev $new"
    fi
    return 0
}

log "m9-rtr-agent up: $SYNC_URL every ${INTERVAL}s (pubkey ${ROUTER_PUBKEY:-?})"
boot_select
while :; do
    sync_once || true
    sleep "$INTERVAL"
done
