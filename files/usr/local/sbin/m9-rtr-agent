#!/bin/sh
# m9-rtr-agent — keeps this router's split policy in sync with the M9 dashboard.
#
# Every AGENT_INTERVAL it POSTs a status report to $DASHBOARD_URL/api/rtr/sync
# (auth: X-Router-Token) and receives the current policy + entry-point endpoints.
# When the policy rev moves, it persists the response to $POLICY_JSON and runs
# wg-split-apply, which regenerates the nft/dnsmasq layer and routing.
#
# Pure busybox: curl + jsonfilter. Runs under procd (see /etc/init.d/m9-rtr-agent).
set -u
. /usr/local/lib/wg-split/common.sh

[ -n "${DASHBOARD_URL:-}" ] || die "DASHBOARD_URL not set in $CONF_FILE"
[ -n "${ROUTER_TOKEN:-}" ]  || die "ROUTER_TOKEN not set in $CONF_FILE"
INTERVAL="${AGENT_INTERVAL:-30}"
INSECURE=""; [ "${AGENT_TLS_INSECURE:-0}" = "1" ] && INSECURE="-k"
SYNC_URL="${DASHBOARD_URL%/}/api/rtr/sync"
RESP="/tmp/m9-rtr-sync.json"

# Capabilities this agent advertises in every status report so the dashboard
# negotiates features by what we support instead of guessing from our version
# (see m9-core/manifest.yaml). Comma-separated; additive — an older dashboard
# simply ignores the field. Keep in sync with capabilities.router_sync there.
CAPS="slim,telemetry,auto_update,backoff,caps"

applied_rev() { [ -r "$POLICY_ENV" ] && . "$POLICY_ENV"; echo "${APPLIED_REV:-0}"; }

# JSON array of current LAN devices from the DHCP lease file: ip/mac/host.
devices_json() {
    _f=/tmp/dhcp.leases
    [ -r "$_f" ] || { echo "[]"; return; }
    awk '{ printf "%s{\"ip\":\"%s\",\"mac\":\"%s\",\"host\":\"%s\"}",
                  (NR>1?",":""), $3, $2, ($4=="*"?"":$4) }
         END { print "" }' "$_f" 2>/dev/null | sed 's/^/[/; s/$/]/'
}

json_bool() { [ "${1:-0}" = "1" ] && echo true || echo false; }

list_count() {
    [ -r "$1" ] || { echo 0; return; }
    awk '
        /^[[:space:]]*($|#)/ { next }
        { n++ }
        END { print n + 0 }
    ' "$1" 2>/dev/null || echo 0
}

mem_kb() {
    awk -v k="$1:" '$1 == k { print $2; found = 1; exit } END { if (!found) print 0 }' \
        /proc/meminfo 2>/dev/null
}

zapret_available() {
    [ -n "${ZAPRET_INIT:-}" ] && [ -x "$ZAPRET_INIT" ] && return 0
    [ -x /opt/zapret/nfq/nfqws ] && return 0
    command -v nfqws >/dev/null 2>&1 && return 0
    zapret_running && return 0
    return 1
}

zapret_running() {
    (ps w 2>/dev/null || ps 2>/dev/null) | grep -q '[n]fqws'
}

# Heavy telemetry (nft set dumps, list file counts, zapret probes) — built by
# sync_once only every TELEMETRY_EVERY-th poll; the dashboard carries the last
# reported values over in between. Keeps the steady-state sync cheap.
telemetry_fields() {
    _zap_av=0; zapret_available && _zap_av=1
    _zap_run=0; zapret_running && _zap_run=1
    printf ',"zapret_available":%s,"zapret_enabled":%s,"zapret_running":%s' \
           "$(json_bool "$_zap_av")" "$(json_bool "${ZAPRET_ENABLED:-0}")" "$(json_bool "$_zap_run")"
    printf ',"ipsum_nft_count":%s,"ru_nft_count":%s,"nozapret_nft_count":%s' \
           "$(set_count "$IPSUM_TABLE" "$IPSUM_SET")" \
           "$(set_count "$RU_TABLE" "$RU_SET")" \
           "$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")"
    printf ',"ipsum_list_count":%s,"ru_list_count":%s,"mem_total_kb":%s,"mem_available_kb":%s' \
           "$(list_count "$IPSUM_FILE")" "$(list_count "$RU_FILE")" \
           "$(mem_kb MemTotal)" "$(mem_kb MemAvailable)"
}

build_status() {
    _ver="$(cat /etc/wg-split/VERSION 2>/dev/null || echo dev)"
    _up="$(cut -d. -f1 /proc/uptime 2>/dev/null || echo 0)"
    _wan="$(ip -4 -o addr show 2>/dev/null | awk '/ wan@| wan /{print $4}' | cut -d/ -f1 | head -1)"
    # one `wg dump` gives handshake + transfer in a single spawn (fields 5/6/7
    # of the first peer line = latest-handshake, rx, tx)
    set -- $(wgshow "$VPN_IFACE" dump 2>/dev/null | awk 'NR==2{print $5, $6, $7}') 0 0 0
    _hs="$1"; _rx="$2"; _tx="$3"
    _hsage=999999
    [ "${_hs:-0}" -gt 0 ] 2>/dev/null && _hsage=$(( $(date +%s) - _hs ))
    _err=""; [ "$(read_state)" = "wan" ] && _err="vpn-down-fallback-wan"
    printf '{"version":"%s","uptime":%s,"wan_ip":"%s","lan_if":"%s","wg_if":"%s",' \
           "$_ver" "$_up" "${_wan:-}" "$LAN_IFACE" "$VPN_IFACE"
    _entry="$(cat "${CHOSEN_FILE:-/var/run/wg-split-endpoint}" 2>/dev/null)"
    _mtu="$(cat /var/run/wg-split-mtu 2>/dev/null || echo 1280)"
    # slim=1: the dashboard omits policy+endpoints unless our applied rev is
    # stale, the portal host moved, or we ask for a full reply (lost endpoints)
    _need_full=0
    [ -n "$(jsonfilter -i "$POLICY_JSON" -e '@.endpoints[0].name' 2>/dev/null)" ] || _need_full=1
    _portal="$(jsonfilter -i "$POLICY_JSON" -e '@.portal_host' 2>/dev/null)"
    printf '"applied_rev":%s,"handshake_age":%s,"rx":%s,"tx":%s,"entry":"%s","mtu":%s,"error":"%s",' \
           "$(applied_rev)" "$_hsage" "$_rx" "$_tx" "${_entry:-}" "$_mtu" "$_err"
    printf '"slim":1,"need_full":%s,"portal_host":"%s","caps":"%s"%s%s}' \
           "$_need_full" "$_portal" "$CAPS" "$TELEMETRY_FIELD" "$DEV_FIELD"
}

# Boot-time endpoint autoselect (once): probe candidates and switch to the best.
# Runs from the persisted policy.json even before the dashboard is reachable.
boot_select() {
    [ "${AUTO_ENDPOINT:-0}" = "1" ] || return 0
    [ -x /usr/local/sbin/wg-split-endpoint ] || return 0
    [ -r "$POLICY_JSON" ] || return 0
    log "boot: autoselecting best endpoint (curl probe)"
    /usr/local/sbin/wg-split-endpoint --auto >/dev/null 2>&1 || warn "boot autoselect found no endpoint"
}

# Devices ride along only when the lease file changed; heavy telemetry and a
# devices refresh go every TELEMETRY_EVERY-th sync (covers dashboard restarts).
TELEMETRY_EVERY=10
DEV_SENT_HASH="-"
SYNC_N=0

sync_once() {
    SYNC_N=$((SYNC_N + 1))
    _periodic=0; [ $((SYNC_N % TELEMETRY_EVERY)) = 1 ] && _periodic=1
    TELEMETRY_FIELD=""
    [ "$_periodic" = 1 ] && TELEMETRY_FIELD="$(telemetry_fields)"
    _devhash="$(md5sum /tmp/dhcp.leases 2>/dev/null | cut -d' ' -f1)"
    DEV_FIELD=""
    if [ "$_devhash" != "$DEV_SENT_HASH" ] || [ "$_periodic" = 1 ]; then
        DEV_FIELD=",\"devices\":$(devices_json)"
    fi
    body="$(build_status)"
    if ! curl $INSECURE -fsS --max-time 20 \
            -H "X-Router-Token: $ROUTER_TOKEN" \
            -H "Content-Type: application/json" \
            -X POST --data "$body" "$SYNC_URL" -o "$RESP" 2>/dev/null; then
        warn "sync failed: unreachable $SYNC_URL"
        return 1
    fi
    [ "$(jsonfilter -i "$RESP" -e '@.ok' 2>/dev/null)" = "true" ] || {
        warn "sync rejected: $(jsonfilter -i "$RESP" -e '@.error' 2>/dev/null || echo '?')"
        return 1
    }
    [ -n "$DEV_FIELD" ] && DEV_SENT_HASH="$_devhash"
    # the dashboard can retune our poll interval centrally (rtr_sync_interval).
    # Strip leading zeros first: a value like "099" passes the digit/range checks
    # but later trips $((INTERVAL * 6)) in the backoff path, where the shell parses
    # a leading-zero literal as octal ("9"/"8" invalid) and aborts the agent.
    _iv="$(jsonfilter -i "$RESP" -e '@.interval' 2>/dev/null)"
    case "$_iv" in
        (*[!0-9]*|"") ;;
        (*) _iv="$(echo "$_iv" | sed 's/^0*//')"; [ -n "$_iv" ] || _iv=0
            [ "$_iv" -ge 10 ] && [ "$_iv" -le 3600 ] && INTERVAL="$_iv" ;;
    esac
    update_url="$(jsonfilter -i "$RESP" -e '@.update_url' 2>/dev/null || true)"
    if [ -n "$update_url" ]; then
        # only ever execute update scripts served by OUR dashboard; the token
        # also auths the download so a 3rd party can't serve us a payload
        case "$update_url" in
            "${DASHBOARD_URL%/}"/*) ;;
            *) warn "auto-update refused: $update_url not under $DASHBOARD_URL"; update_url="" ;;
        esac
    fi
    if [ -n "$update_url" ]; then
        log "auto-update requested via sync, downloading $update_url"
        # NO -L: curl must not follow redirects, or it would forward X-Router-Token
        # to the redirect target (cross-origin token leak). But WITHOUT -L a 3xx
        # still exits 0 and writes the redirect BODY to the file (-f/--fail only
        # trips on >=400), so we additionally gate on the HTTP status: capture it
        # with -w and execute ONLY a non-empty 2xx payload. A redirect/login/error
        # page is refused and discarded, never run as a root shell script.
        _code="$(curl $INSECURE -sS --max-time 60 -H "X-Router-Token: $ROUTER_TOKEN" \
                 -o /tmp/agent-update.sh -w '%{http_code}' "$update_url" 2>/dev/null)"
        case "${_code:-000}" in
            2[0-9][0-9])
                if [ -s /tmp/agent-update.sh ]; then
                    # procd respawns us after exit; the update script also restarts the service
                    sh /tmp/agent-update.sh >/dev/null 2>&1 &
                    exit 0
                fi
                warn "auto-update: empty 2xx payload, skipping" ;;
            *)
                rm -f /tmp/agent-update.sh
                warn "auto-update refused: HTTP ${_code:-?} (redirect/error body not executed)" ;;
        esac
    fi

    new="$(jsonfilter -i "$RESP" -e '@.rev' 2>/dev/null)"; new="${new:-0}"
    cur="$(applied_rev)"
    has_endpoints="$(jsonfilter -i "$POLICY_JSON" -e '@.endpoints[0].name' 2>/dev/null)"
    cur_portal="$(jsonfilter -i "$POLICY_JSON" -e '@.portal_host' 2>/dev/null)"
    new_portal="$(jsonfilter -i "$RESP" -e '@.portal_host' 2>/dev/null)"
    if [ "$new" != "$cur" ] || [ -z "$has_endpoints" ] || [ "$new_portal" != "$cur_portal" ]; then
        # slim replies carry no policy — only persist a full one (the server
        # sends it whenever our applied_rev/portal is stale or need_full is set)
        if [ -z "$(jsonfilter -i "$RESP" -e '@.policy.mode' 2>/dev/null)" ]; then
            warn "rev $cur -> $new but reply has no policy; waiting for full sync"
            return 0
        fi
        log "policy rev $cur -> $new (or endpoints/portal changed); applying"
        cp "$RESP" "$POLICY_JSON"
        /usr/local/sbin/wg-split-apply >/dev/null 2>&1 \
            && log "policy rev $new applied" \
            || warn "wg-split-apply failed for rev $new"
    fi
    return 0
}

log "m9-rtr-agent up: $SYNC_URL every ${INTERVAL}s (pubkey ${ROUTER_PUBKEY:-?})"
boot_select
# Poll on $INTERVAL while healthy; when the dashboard is unreachable/rejecting,
# ramp the wait exponentially (capped) so a control-plane outage doesn't keep a
# router spinning curl + waking the CPU/radio every 30 s — it resets to the base
# interval the instant a sync succeeds. Pure client-side timing; no protocol change.
BACKOFF=0
while :; do
    if sync_once; then
        BACKOFF=0
        sleep "$INTERVAL"
    else
        if [ "$BACKOFF" -gt 0 ]; then BACKOFF=$((BACKOFF * 2)); else BACKOFF="$INTERVAL"; fi
        _bmax=$((INTERVAL * 6)); [ "$_bmax" -gt 300 ] && _bmax=300
        [ "$BACKOFF" -gt "$_bmax" ] && BACKOFF="$_bmax"
        sleep "$BACKOFF"
    fi
done
