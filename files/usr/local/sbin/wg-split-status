#!/bin/sh
# wg-split-status — print runtime snapshot for debugging.

set -u
. /usr/local/lib/wg-split/common.sh

echo "=== wg-split status ==="
echo "VPN_IFACE     : $VPN_IFACE"
echo "STATE         : $(read_state)"
echo "FAIL_COUNTER  : $(fail_get)"
echo

echo "=== ip rules ==="
ip -4 rule show | grep -E "($WG_RULE_PRIO|$ANTI_LOOP_PRIO):" || echo "(no wg-split rules)"
echo

echo "=== route table $WG_TABLE ==="
ip -4 route show table "$WG_TABLE" 2>/dev/null || echo "(table empty)"
echo

echo "=== nft sets ==="
printf 'ipsum (%s %s): %s entries\n' "$IPSUM_TABLE" "$IPSUM_SET" \
    "$(set_count "$IPSUM_TABLE" "$IPSUM_SET")"
printf 'ru    (%s %s): %s entries\n' "$RU_TABLE" "$RU_SET" \
    "$(set_count "$RU_TABLE" "$RU_SET")"
printf 'noz   (%s %s): %s entries\n' "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET" \
    "$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")"
echo

echo "=== nft mangle chains ==="
nft list chain inet fw4 wg_split_endpoint_mark_prerouting 2>/dev/null \
    | sed 's/^/  /' || echo "(endpoint chain missing)"
nft list chain inet fw4 wg_split_ipsum_mark_prerouting 2>/dev/null \
    | sed 's/^/  /' || echo "(ipsum chain missing)"
echo

echo "=== VPN link ==="
ip link show dev "$VPN_IFACE" 2>/dev/null | sed 's/^/  /' || echo "  (link absent)"
echo

echo "=== health probe (method=$HEALTH_METHOD) ==="
case "$HEALTH_METHOD" in
    ping)
        for _t in $HEALTH_PING_TARGETS; do
            if ping -I "$VPN_IFACE" -c 1 -W "$HEALTH_PING_TIMEOUT" -q "$_t" >/dev/null 2>&1; then
                echo "  $_t : OK"
            else
                echo "  $_t : FAIL"
            fi
        done
        ;;
    curl)
        if curl --interface "$VPN_IFACE" --max-time "$HEALTH_CURL_TIMEOUT" -fsS -o /dev/null "$HEALTH_CURL_URL"; then
            echo "  $HEALTH_CURL_URL : OK"
        else
            echo "  $HEALTH_CURL_URL : FAIL"
        fi
        ;;
esac
