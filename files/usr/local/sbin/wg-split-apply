#!/bin/sh
# wg-split-apply — regenerate the policy-derived layer from /etc/wg-split/policy.json.
#
# Called by m9-rtr-agent whenever the dashboard policy rev changes (and runnable
# by hand for debugging). It is the ONLY writer of:
#   /etc/wg-split/policy.env       (MODE / IPSUM_ENABLED / KILLSWITCH / WG_ENDPOINTS)
#   /etc/nftables.d/30-wg-split.nft (the canonical ruleset, regenerated in place —
#                                    same chain/set names as the reference split)
#   $DNSMASQ_NFTSET_FILE           (domain -> nftset lines for dnsmasq)
# then switches the AmneziaWG peer endpoint if the chosen entry point changed,
# reloads fw4 + dnsmasq, and re-runs the watchdog to (re)install routes/rules.
#
# policy.json is the verbatim object the dashboard serves; parsed with jsonfilter
# (OpenWrt base, always present).
set -u
. /usr/local/lib/wg-split/common.sh

POLICY_JSON="${POLICY_JSON:-/etc/wg-split/policy.json}"
[ -r "$POLICY_JSON" ] || die "no policy file: $POLICY_JSON"

# effective list URLs BEFORE this apply (conf default or previous policy.env), so
# we can detect a dashboard-driven URL change and refresh the set immediately.
OLD_IPSUM_URL="${IPSUM_URL:-}"; OLD_RU_URL="${RU_URL:-}"

# policy.json is the raw /api/rtr/sync response: { policy:{...}, endpoints:{...} }
jf() { jsonfilter -i "$POLICY_JSON" -e "$1" 2>/dev/null; }

REV="$(jf '@.policy.rev')";          REV="${REV:-0}"
P_MODE="$(jf '@.policy.mode')";      P_MODE="${P_MODE:-blocklist}"
P_ENTRY="$(jf '@.policy.entry')"
P_IPSUM="$(jf '@.policy.ipsum')";    [ "$P_IPSUM" = "false" ] && P_IPSUM=0 || P_IPSUM=1
P_ZAPRET="$(jf '@.policy.zapret')";  [ "$P_ZAPRET" = "false" ] && P_ZAPRET=0 || P_ZAPRET=1
P_RU="$(jf '@.policy.ru_direct')";   [ "$P_RU" = "false" ] && P_RU=0 || P_RU=1
P_KILL="$(jf '@.policy.killswitch')"; [ "$P_KILL" = "true" ] && P_KILL=1 || P_KILL=0
P_DNSVPN="$(jf '@.policy.dns_via_vpn')"; [ "$P_DNSVPN" = "true" ] && P_DNSVPN=1 || P_DNSVPN=0

P_IPSUM_URL="$(jf '@.policy.ipsum_url')"
P_RU_URL="$(jf '@.policy.ru_url')"
P_PROBE_URL="$(jf '@.policy.probe_url')"
P_RELAY_FB="$(jf '@.policy.relay_fallback')"; [ "$P_RELAY_FB" = "false" ] && P_RELAY_FB=0 || P_RELAY_FB=1
# entry "" or "auto" => probe & autoselect (boot/failover); else a pinned candidate
P_AUTO=0; { [ -z "$P_ENTRY" ] || [ "$P_ENTRY" = "auto" ]; } && P_AUTO=1

list() { jsonfilter -i "$POLICY_JSON" -e "$1" 2>/dev/null | tr ' ' '\n' | grep -v '^$'; }
VPN_CIDRS="$(list '@.policy.vpn_cidrs[*]')"
DIRECT_CIDRS="$(list '@.policy.direct_cidrs[*]')"
VPN_DOMAINS="$(list '@.policy.vpn_domains[*]')"
DIRECT_DOMAINS="$(list '@.policy.direct_domains[*]')"

# ---- 1. policy.env (knobs the static scripts read) -------------------------
# Endpoint selection is delegated to wg-split-endpoint (step 4); here we only
# need a fallback for the nft anti-loop daddr when the live tunnel is down (the
# generator otherwise resolves the running endpoint via `awg show`).
ENDPOINTS_FOR_NFT="$WG_ENDPOINTS"

sq() { awk '{gsub(/'\''/,"'\''\\'\'\''"); print}' ; }

{
    echo "# Generated by wg-split-apply from policy rev $REV — do not edit by hand."
    echo "MODE='$(echo "$P_MODE" | sq)'"
    echo "IPSUM_ENABLED='$(echo "$P_IPSUM" | sq)'"
    echo "ZAPRET_ENABLED='$(echo "$P_ZAPRET" | sq)'"
    echo "RU_ENABLED='$(echo "$P_RU" | sq)'"
    echo "KILLSWITCH='$(echo "$P_KILL" | sq)'"
    echo "DNS_VIA_VPN='$(echo "$P_DNSVPN" | sq)'"
    echo "WG_ENDPOINTS='$(echo "$ENDPOINTS_FOR_NFT" | sq)'"
    # endpoint selection (auto-probe vs pinned) — read by watchdog + agent
    echo "ENTRY='$(echo "$P_ENTRY" | sq)'"
    echo "AUTO_ENDPOINT='$(echo "$P_AUTO" | sq)'"
    echo "RELAY_FALLBACK='$(echo "$P_RELAY_FB" | sq)'"
    [ -n "$P_PROBE_URL" ] && echo "PROBE_URL='$(echo "$P_PROBE_URL" | sq)'"
    # dashboard-managed list sources — override the conf defaults when set, so the
    # daily updater (and the immediate refresh below) pull from these URLs.
    [ -n "$P_IPSUM_URL" ] && echo "IPSUM_URL='$(echo "$P_IPSUM_URL" | sq)'"
    [ -n "$P_RU_URL" ]    && echo "RU_URL='$(echo "$P_RU_URL" | sq)'"
    echo "APPLIED_REV='$(echo "$REV" | sq)'"
} > "$POLICY_ENV"

# ---- 2. nft ruleset (canonical 30-wg-split.nft) ----------------------------
# Regenerated to be IDENTICAL to the hand-built reference split: same chain
# names (wg_split_endpoint_mark_prerouting @ mangle, wg_split_ipsum_mark_prerouting
# @ mangle+1), same set (wg_split_ipsum_v4), same 0x40000(VPN)/0x10000(anti-loop)
# marks. In the baseline (mode=blocklist, no vpn/direct/device extras) the output
# is byte-for-byte the reference ruleset. Extras add ONLY when present:
#   device overrides  @ mangle-2   (saddr = LAN host, earliest decisive)
#   force-direct set  @ mangle-1   (forced WAN)
# fw4 inline-includes this INSIDE `table inet fw4 { }`, so it is pure declarative
# (set/chain) — NO `add element`; the ipsum set stays empty here and is filled
# live by wg-split-update-ipsum / watchdog (daily refresh preserved).
emit_set() {  # $1 set name, $2 size, stdin = cidrs
    _items="$(cat | tr '\n' ' ' | sed 's/  */, /g; s/^ *//; s/, *$//')"
    echo "set $1 {"
    echo "    type ipv4_addr; flags interval; auto-merge; size $2;"
    [ -n "$_items" ] && echo "    elements = { $_items }"
    echo "}"
}

# resolve the WG endpoint to the IP packets actually go to (anti-loop matches an
# IP, not a hostname). Prefer the live kernel endpoint, then DNS, then config.
EP_IPS="$( { awg show "$VPN_IFACE" endpoints 2>/dev/null; wg show "$VPN_IFACE" endpoints 2>/dev/null; } \
            | awk '{print $2}' | sed 's/:[0-9]*$//' | grep -E '^[0-9]+\.' | sort -u | tr '\n' ' ')"
if [ -z "$EP_IPS" ]; then
    for h in $ENDPOINTS_FOR_NFT; do
        case "$h" in
            *[!0-9.]*) EP_IPS="$EP_IPS $(nslookup "$h" 2>/dev/null | awk '/^Address/{print $NF}' | grep -E '^[0-9]+\.' | head -1)" ;;
            *) EP_IPS="$EP_IPS $h" ;;
        esac
    done
fi
ep_braces="$(echo "$EP_IPS" | tr ' ' '\n' | grep -E '^[0-9]' | paste -sd, - 2>/dev/null)"
[ -n "$ep_braces" ] || ep_braces="$(echo "$EP_IPS" | tr ' ' '\n' | grep -E '^[0-9]' | tr '\n' ',' | sed 's/,$//')"

# emit vpn/direct sets only when actually used (so the baseline stays identical)
HAS_VPN=0;    { [ -n "$VPN_CIDRS" ]    || [ -n "$VPN_DOMAINS" ]; }    && HAS_VPN=1
HAS_DIRECT=0; { [ -n "$DIRECT_CIDRS" ] || [ -n "$DIRECT_DOMAINS" ]; } && HAS_DIRECT=1
HAS_DEV=0;    [ -n "$(jsonfilter -i "$POLICY_JSON" -e '@.policy.devices[0].ip' 2>/dev/null)" ] && HAS_DEV=1

{
    echo "# wg-split — regenerated by wg-split-apply (policy rev $REV, mode $P_MODE)."
    echo "# Canonical ruleset; identical to the reference split. DO NOT EDIT."
    emit_set "$IPSUM_SET" 65536 </dev/null    # defined empty; filled live (daily refresh)
    [ "$HAS_VPN" = 1 ]    && { echo "$VPN_CIDRS"    | emit_set "$VPN_SET" 4096; }
    [ "$HAS_DIRECT" = 1 ] && { echo "$DIRECT_CIDRS" | emit_set "$DIRECT_SET" 4096; }

    # per-device overrides — earliest, win over everything
    if [ "$HAS_DEV" = 1 ]; then
        echo "chain wg_split_device_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle - 2; policy accept;"
        n=0
        while :; do
            dip="$(jsonfilter -i "$POLICY_JSON" -e "@.policy.devices[$n].ip" 2>/dev/null)"
            [ -n "$dip" ] || break
            dmode="$(jsonfilter -i "$POLICY_JSON" -e "@.policy.devices[$n].mode" 2>/dev/null)"
            [ "$dmode" = "vpn" ]    && echo "    ip saddr $dip meta mark set meta mark or $WG_MARK counter"
            [ "$dmode" = "direct" ] && echo "    ip saddr $dip meta mark set meta mark or $ANTI_LOOP_MARK counter"
            n=$((n + 1))
        done
        echo "}"
    fi

    # force-direct CIDRs/domains -> WAN (before the policy chain)
    if [ "$HAS_DIRECT" = 1 ]; then
        echo "chain wg_split_direct_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle - 1; policy accept;"
        echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$DIRECT_SET meta mark set meta mark or $ANTI_LOOP_MARK counter"
        echo "}"
    fi

    # endpoint anti-loop (reference chain, priority mangle)
    if [ -n "$ep_braces" ]; then
        echo "chain wg_split_endpoint_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle; policy accept;"
        echo "    ip saddr { $LAN_CIDR } ip daddr { $ep_braces } meta mark set meta mark or $ANTI_LOOP_MARK counter"
        echo "}"
    fi

    # policy chain (reference name/priority): which UNmarked LAN traffic -> VPN
    echo "chain wg_split_ipsum_mark_prerouting {"
    echo "    type filter hook prerouting priority mangle + 1; policy accept;"
    [ "$HAS_VPN" = 1 ] && \
    echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$VPN_SET meta mark set meta mark or $WG_MARK counter"
    case "$P_MODE" in
        blocklist)
            [ "$P_IPSUM" = "1" ] && \
            echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$IPSUM_SET meta mark set meta mark or $WG_MARK counter" ;;
        full)
            echo "    ip saddr { $LAN_CIDR } meta mark 0x0 meta mark set meta mark or $WG_MARK counter" ;;
        split) : ;;
    esac
    echo "}"
} > "${POLICY_NFT_FILE}.tmp"
mv "${POLICY_NFT_FILE}.tmp" "$POLICY_NFT_FILE"

# ---- 3. dnsmasq domain -> nftset (resolve-time tagging) --------------------
# The live dnsmasq's conf-dir wins over the configured path: on instanced
# OpenWrt builds it's /tmp/dnsmasq.cfgXXXX.d, NOT /tmp/dnsmasq.d — drop-ins in
# the wrong dir are silently ignored.
DNSMASQ_DIR="$(sed -n 's/^conf-dir=//p' /var/etc/dnsmasq.conf* 2>/dev/null | head -1)"
[ -n "$DNSMASQ_DIR" ] || DNSMASQ_DIR="$(dirname "$DNSMASQ_NFTSET_FILE")"
mkdir -p "$DNSMASQ_DIR"
{
    echo "# Generated by wg-split-apply — policy rev $REV."
    for d in $VPN_DOMAINS;    do echo "nftset=/$d/4#inet#fw4#$VPN_SET"; done
    for d in $DIRECT_DOMAINS; do echo "nftset=/$d/4#inet#fw4#$DIRECT_SET"; done
} > "$DNSMASQ_DIR/$(basename "$DNSMASQ_NFTSET_FILE")"

# split.local -> dashboard portal. dnsmasq address=/name/VALUE needs an IP;
# writing a hostname here would make dnsmasq refuse its whole config (DNS down),
# so only map when the dashboard URL host is a literal IPv4.
DURL="$(grep -i 'DASHBOARD_URL=' /etc/wg-split/wg-split.conf | cut -d'"' -f2 || true)"
DHOST="$(echo "$DURL" | sed -n 's#https\?://\([^:/]*\).*#\1#p')"
if echo "$DHOST" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "address=/split.local/$DHOST" > "$DNSMASQ_DIR/wg-split-portal.conf"
else
    rm -f "$DNSMASQ_DIR/wg-split-portal.conf"
fi

# ---- 4. entry point: pin a specific candidate; leave auto to boot/failover --
# (auto-probing bounces the tunnel per candidate, so we DON'T do it on every
# policy save — the agent does it at boot and the watchdog on failure.)
if [ "$P_AUTO" != "1" ] && [ -x /usr/local/sbin/wg-split-endpoint ] && [ -n "$P_ENTRY" ]; then
    if [ "$(cat "${CHOSEN_FILE:-/var/run/wg-split-endpoint}" 2>/dev/null)" != "$P_ENTRY" ]; then
        /usr/local/sbin/wg-split-endpoint --pin "$P_ENTRY" >/dev/null 2>&1 || true
    fi
fi

# ---- 5. reload + re-apply routing ------------------------------------------
fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1 || true
# restart, not reload: SIGHUP does not re-read conf-dir drop-ins
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
[ -x /usr/local/sbin/wg-split-watchdog ] && /usr/local/sbin/wg-split-watchdog >/dev/null 2>&1 || true

# ---- 6. list-source change -> pull the new list NOW (background; daily cron
# keeps refreshing from the same URL). The updaters re-source policy.env, so they
# already see the new URL written above.
if [ -n "$P_IPSUM_URL" ] && [ "$P_IPSUM_URL" != "$OLD_IPSUM_URL" ]; then
    log "ipsum source changed -> $P_IPSUM_URL; refreshing now (background)"
    /usr/local/sbin/wg-split-update-ipsum >/dev/null 2>&1 &
fi
if [ -n "$P_RU_URL" ] && [ "$P_RU_URL" != "$OLD_RU_URL" ]; then
    log "ru source changed -> $P_RU_URL; refreshing now (background)"
    /usr/local/sbin/wg-split-update-ru >/dev/null 2>&1 &
fi

log "applied policy rev $REV: mode=$P_MODE ipsum=$P_IPSUM zapret=$P_ZAPRET kill=$P_KILL entry=${P_ENTRY:-keep} vpn_cidrs=$(echo $VPN_CIDRS | wc -w) direct_cidrs=$(echo $DIRECT_CIDRS | wc -w)"
echo "$REV"
