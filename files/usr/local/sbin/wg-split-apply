#!/bin/sh
# wg-split-apply — regenerate the policy-derived layer from /etc/wg-split/policy.json.
#
# Called by m9-rtr-agent whenever the dashboard policy rev changes (and runnable
# by hand for debugging). It is the ONLY writer of:
#   /etc/wg-split/policy.env            (MODE / IPSUM_ENABLED / KILLSWITCH / WG_ENDPOINTS)
#   /etc/nftables.d/31-wg-split-policy.nft   (device + direct + mode mark chains, vpn/direct elements)
#   $DNSMASQ_NFTSET_FILE                (domain -> nftset lines for dnsmasq)
# then switches the AmneziaWG peer endpoint if the chosen entry point changed,
# reloads fw4 + dnsmasq, and re-runs the watchdog to (re)install routes/rules.
#
# policy.json is the verbatim object the dashboard serves; parsed with jsonfilter
# (OpenWrt base, always present).
set -u
. /usr/local/lib/wg-split/common.sh

POLICY_JSON="${POLICY_JSON:-/etc/wg-split/policy.json}"
[ -r "$POLICY_JSON" ] || die "no policy file: $POLICY_JSON"

# policy.json is the raw /api/rtr/sync response: { policy:{...}, endpoints:{...} }
jf() { jsonfilter -i "$POLICY_JSON" -e "$1" 2>/dev/null; }

REV="$(jf '@.policy.rev')";          REV="${REV:-0}"
P_MODE="$(jf '@.policy.mode')";      P_MODE="${P_MODE:-blocklist}"
P_ENTRY="$(jf '@.policy.entry')"
P_IPSUM="$(jf '@.policy.ipsum')";    [ "$P_IPSUM" = "false" ] && P_IPSUM=0 || P_IPSUM=1
P_ZAPRET="$(jf '@.policy.zapret')";  [ "$P_ZAPRET" = "false" ] && P_ZAPRET=0 || P_ZAPRET=1
P_RU="$(jf '@.policy.ru_direct')";   [ "$P_RU" = "false" ] && P_RU=0 || P_RU=1
P_KILL="$(jf '@.policy.killswitch')"; [ "$P_KILL" = "true" ] && P_KILL=1 || P_KILL=0
P_DNSVPN="$(jf '@.policy.dns_via_vpn')"; [ "$P_DNSVPN" = "true" ] && P_DNSVPN=1 || P_DNSVPN=0

list() { jsonfilter -i "$POLICY_JSON" -e "$1" 2>/dev/null | tr ' ' '\n' | grep -v '^$'; }
VPN_CIDRS="$(list '@.policy.vpn_cidrs[*]')"
DIRECT_CIDRS="$(list '@.policy.direct_cidrs[*]')"
VPN_DOMAINS="$(list '@.policy.vpn_domains[*]')"
DIRECT_DOMAINS="$(list '@.policy.direct_domains[*]')"

# ---- 1. policy.env (knobs the static scripts read) -------------------------
ENDPOINT_HOST=""; ENDPOINT_PORT=""
if [ -n "$P_ENTRY" ]; then
    ep="$(jsonfilter -i "$POLICY_JSON" -e "@.endpoints['$P_ENTRY'].endpoint" 2>/dev/null)"
    ENDPOINT_HOST="${ep%%:*}"; ENDPOINT_PORT="${ep##*:}"
fi
ENDPOINTS_FOR_NFT="$ENDPOINT_HOST"
[ -n "$ENDPOINTS_FOR_NFT" ] || ENDPOINTS_FOR_NFT="$WG_ENDPOINTS"

cat > "$POLICY_ENV" <<EOF
# Generated by wg-split-apply from policy rev $REV — do not edit by hand.
MODE="$P_MODE"
IPSUM_ENABLED="$P_IPSUM"
ZAPRET_ENABLED="$P_ZAPRET"
RU_ENABLED="$P_RU"
KILLSWITCH="$P_KILL"
DNS_VIA_VPN="$P_DNSVPN"
WG_ENDPOINTS="$ENDPOINTS_FOR_NFT"
APPLIED_REV="$REV"
EOF

# ---- 2. nft policy chains --------------------------------------------------
# Priorities (lower = earlier within the prerouting hook):
#   endpoint anti-loop : mangle-2   direct : mangle    device : mangle-1   policy : mangle+1
# Marks accumulate; ip rule prio 999 (wg 0x40000) is checked before 1000
# (anti-loop 0x10000 -> main/WAN). The policy chain only marks UNmarked packets
# (`meta mark 0x0`), so a device/direct anti-loop mark suppresses VPN routing.
# fw4 inline-includes this file INSIDE `table inet fw4 { ... }`, so it must be
# pure declarative (set/chain blocks) — NO imperative `add element`. The vpn /
# direct set CONTENTS go inline here; ipsum's set is defined in 30 and filled
# live by the updater. emit_set prints a declarative set with inline elements.
emit_set() {  # $1 set name, stdin = cidrs
    _items="$(cat | tr '\n' ' ' | sed 's/  */, /g; s/^ *//; s/, *$//')"
    echo "set $1 {"
    echo "    type ipv4_addr; flags interval; auto-merge; size 4096;"
    [ -n "$_items" ] && echo "    elements = { $_items }"
    echo "}"
}
ep_braces=""; for e in $ENDPOINTS_FOR_NFT; do ep_braces="$ep_braces $e,"; done
ep_braces="$(echo "$ep_braces" | sed 's/,$//; s/^ //')"

{
    echo "# Generated by wg-split-apply — policy rev $REV, mode $P_MODE. DO NOT EDIT."
    echo "$VPN_CIDRS"    | emit_set "$VPN_SET"
    echo "$DIRECT_CIDRS" | emit_set "$DIRECT_SET"

    # endpoint anti-loop: the tunnel's own packets to the WG endpoint go via main
    if [ -n "$ep_braces" ]; then
        echo "chain wg_split_endpoint_mark {"
        echo "    type filter hook prerouting priority mangle - 2; policy accept;"
        echo "    ip saddr { $LAN_CIDR } ip daddr { $ep_braces } meta mark set meta mark or $ANTI_LOOP_MARK counter"
        echo "}"
    fi

    # per-device overrides (saddr = LAN host), earliest decisive
    echo "chain wg_split_device_mark {"
    echo "    type filter hook prerouting priority mangle - 1; policy accept;"
    n=0
    while :; do
        dip="$(jsonfilter -i "$POLICY_JSON" -e "@.policy.devices[$n].ip" 2>/dev/null)"
        [ -n "$dip" ] || break
        dmode="$(jsonfilter -i "$POLICY_JSON" -e "@.policy.devices[$n].mode" 2>/dev/null)"
        if [ "$dmode" = "vpn" ]; then
            echo "    ip saddr $dip meta mark set meta mark or $WG_MARK counter"
        elif [ "$dmode" = "direct" ]; then
            echo "    ip saddr $dip meta mark set meta mark or $ANTI_LOOP_MARK counter"
        fi
        n=$((n + 1))
    done
    echo "}"

    # forced-direct CIDRs win over any VPN policy below
    echo "chain wg_split_direct_mark {"
    echo "    type filter hook prerouting priority mangle; policy accept;"
    echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$DIRECT_SET meta mark set meta mark or $ANTI_LOOP_MARK counter"
    echo "}"

    # mode policy: decide which UNmarked LAN traffic rides the VPN
    echo "chain wg_split_policy_mark {"
    echo "    type filter hook prerouting priority mangle + 1; policy accept;"
    echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$VPN_SET meta mark set meta mark or $WG_MARK counter"
    case "$P_MODE" in
        blocklist)
            [ "$P_IPSUM" = "1" ] && \
            echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$IPSUM_SET meta mark set meta mark or $WG_MARK counter" ;;
        full)
            echo "    ip saddr { $LAN_CIDR } meta mark 0x0 meta mark set meta mark or $WG_MARK counter" ;;
        split) : ;;   # only @vpn (line above) goes via VPN
    esac
    echo "}"
} > "${POLICY_NFT_FILE}.tmp"
mv "${POLICY_NFT_FILE}.tmp" "$POLICY_NFT_FILE"

# ---- 3. dnsmasq domain -> nftset (resolve-time tagging) --------------------
mkdir -p "$(dirname "$DNSMASQ_NFTSET_FILE")"
{
    echo "# Generated by wg-split-apply — policy rev $REV."
    for d in $VPN_DOMAINS;    do echo "nftset=/$d/4#inet#fw4#$VPN_SET"; done
    for d in $DIRECT_DOMAINS; do echo "nftset=/$d/4#inet#fw4#$DIRECT_SET"; done
} > "$DNSMASQ_NFTSET_FILE"

# ---- 4. switch AmneziaWG entry-point endpoint if it changed ----------------
if [ -n "$ENDPOINT_HOST" ] && command -v uci >/dev/null 2>&1; then
    sec="$(uci show network 2>/dev/null | sed -n "s/^network\.\(@amneziawg_${VPN_IFACE}\[[0-9]*\]\)=.*/\1/p" | head -1)"
    [ -n "$sec" ] || sec="$(uci show network 2>/dev/null | sed -n "s/^network\.\(@wireguard_${VPN_IFACE}\[[0-9]*\]\)=.*/\1/p" | head -1)"
    if [ -n "$sec" ]; then
        cur="$(uci -q get "network.${sec}.endpoint_host")"
        if [ "$cur" != "$ENDPOINT_HOST" ]; then
            uci set "network.${sec}.endpoint_host=$ENDPOINT_HOST"
            [ -n "$ENDPOINT_PORT" ] && [ "$ENDPOINT_PORT" != "$ENDPOINT_HOST" ] && \
                uci set "network.${sec}.endpoint_port=$ENDPOINT_PORT"
            uci commit network
            log "entry point -> $P_ENTRY ($ENDPOINT_HOST:$ENDPOINT_PORT); bouncing $VPN_IFACE"
            ifup "$VPN_IFACE" >/dev/null 2>&1 || /etc/init.d/network reload >/dev/null 2>&1 || true
        fi
    fi
fi

# ---- 5. reload + re-apply routing ------------------------------------------
fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1 || true
/etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
[ -x /usr/local/sbin/wg-split-watchdog ] && /usr/local/sbin/wg-split-watchdog >/dev/null 2>&1 || true

log "applied policy rev $REV: mode=$P_MODE ipsum=$P_IPSUM zapret=$P_ZAPRET kill=$P_KILL entry=${P_ENTRY:-keep} vpn_cidrs=$(echo $VPN_CIDRS | wc -w) direct_cidrs=$(echo $DIRECT_CIDRS | wc -w)"
echo "$REV"
