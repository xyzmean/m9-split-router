#!/bin/sh
# wg-split-endpoint — pick / set the WG entry point by curling a probe target
# (m13 by default) THROUGH each candidate tunnel and measuring latency.
#
#   wg-split-endpoint --auto      probe all candidates, switch to the best
#   wg-split-endpoint --pin NAME  set a specific candidate (no probing)
#   wg-split-endpoint --show      print candidates + current
#
# Candidates come from policy.json `@.endpoints[]` (dashboard-provided, ordered):
# tier 1 = direct gateways, tier 2 = relay. The lowest-latency WORKING direct
# wins; the relay (tier 2) is tried only if no direct works and RELAY_FALLBACK=1.
# Probing bounces the tunnel per candidate — meant for boot + failover, not steady
# state. The starting endpoint is restored if every candidate fails.
set -u
. /usr/local/lib/wg-split/common.sh

POLICY_JSON="${POLICY_JSON:-/etc/wg-split/policy.json}"
PROBE_URL="${PROBE_URL:-${DASHBOARD_URL%/}/}"
PROBE_TIMEOUT="${PROBE_TIMEOUT:-6}"
HS_WAIT="${HS_WAIT:-8}"
RELAY_FALLBACK="${RELAY_FALLBACK:-1}"
CHOSEN_FILE="${CHOSEN_FILE:-/var/run/wg-split-endpoint}"
MTU_FILE="/var/run/wg-split-mtu"

peer_sec() {
    uci show network 2>/dev/null | sed -n "s/^network\.\(@amneziawg_${VPN_IFACE}\[[0-9]*\]\)=.*/\1/p" | head -1
}
peer_sec_any() {
    _s="$(peer_sec)"; [ -n "$_s" ] && { echo "$_s"; return; }
    uci show network 2>/dev/null | sed -n "s/^network\.\(@wireguard_${VPN_IFACE}\[[0-9]*\]\)=.*/\1/p" | head -1
}

cur_host() { _s="$(peer_sec_any)"; [ -n "$_s" ] && uci -q get "network.${_s}.endpoint_host"; }
cur_port() { _s="$(peer_sec_any)"; [ -n "$_s" ] && uci -q get "network.${_s}.endpoint_port"; }
cur_pub()  { _s="$(peer_sec_any)"; [ -n "$_s" ] && uci -q get "network.${_s}.public_key"; }
cur_mtu()  { uci -q get "network.$VPN_IFACE.mtu"; }

# set uci endpoint + (optional) server key, then bounce the interface
set_candidate() {  # host port pubkey [mtu]
    _s="$(peer_sec_any)"; [ -n "$_s" ] || { warn "no $VPN_IFACE peer section"; return 1; }
    uci set "network.${_s}.endpoint_host=$1"
    [ -n "$2" ] && uci set "network.${_s}.endpoint_port=$2"
    [ -n "$3" ] && uci set "network.${_s}.public_key=$3"
    [ -n "${4:-}" ] && uci set "network.$VPN_IFACE.mtu=$4"
    uci commit network
    ifup "$VPN_IFACE" >/dev/null 2>&1 || /etc/init.d/network reload >/dev/null 2>&1 || true
}

wait_handshake() {
    _attempts=0
    while [ "$_attempts" -lt 3 ]; do
        _i=0
        while [ "$_i" -lt "$HS_WAIT" ]; do
            _a="$(wg_handshake_age)"
            [ "$_a" -lt 150 ] 2>/dev/null && return 0
            sleep 1; _i=$((_i + 1))
        done
        sleep 2
        _attempts=$((_attempts + 1))
    done
    return 1
}

# bring up a candidate and curl the probe target through it; echo "ms mtu", or fail
probe() {  # host port pubkey tier  -> prints "ms mtu" on success
    # Base MTU: WAN minus WG overhead (busybox grep has no -P; use sed/awk)
    _wan_if=$(ip -4 route show default 2>/dev/null | awk '{print $5}' | head -1)
    _wan_mtu=$(ip link show "$_wan_if" 2>/dev/null | sed -n 's/.* mtu \([0-9]*\).*/\1/p' | head -1)
    _wan_mtu="${_wan_mtu:-1500}"
    _is_pppoe=0
    [ "$(uci -q get network.wan.proto 2>/dev/null)" = "pppoe" ] && _is_pppoe=1
    echo "$_wan_if" | grep -q pppoe && _is_pppoe=1

    _base_mtu=$((_wan_mtu - 80))
    [ "$_is_pppoe" = "1" ] && [ "$_wan_mtu" -gt 1492 ] && _base_mtu=$((1492 - 80))
    [ "$4" = "2" ] && _base_mtu=$((_base_mtu - 40))

    set_candidate "$1" "$2" "$3" "$_base_mtu" || return 1
    wait_handshake || return 1

    # MTU sanity: ping the mesh gateway (inner IP — always answers, unlike
    # arbitrary probe hosts) with a payload sized to the candidate MTU.
    _gw="$(echo "${DASHBOARD_URL:-}" | sed -n 's#https\?://\([^:/]*\).*#\1#p')"
    _gw="${_gw:-10.8.0.1}"
    if ! ping -c 1 -W 2 -s $((_base_mtu - 28)) -I "$VPN_IFACE" "$_gw" >/dev/null 2>&1; then
        _base_mtu=1280
        set_candidate "$1" "$2" "$3" "$_base_mtu" || return 1
        wait_handshake || return 1
        if ! ping -c 1 -W 2 -I "$VPN_IFACE" "$_gw" >/dev/null 2>&1; then
            return 1
        fi
    fi

    _t="$(curl -k --interface "$VPN_IFACE" --max-time "$PROBE_TIMEOUT" -fsS \
              -o /dev/null -w '%{time_total}' "$PROBE_URL" 2>/dev/null)" || return 1
    echo "$_t" | awk -v mtu="$_base_mtu" '{printf "%d %d", ($1*1000)+0.5, mtu}'
}

# read candidate field: $1 index, $2 field
cf() { jsonfilter -i "$POLICY_JSON" -e "@.endpoints[$1].$2" 2>/dev/null; }

n_candidates() {
    _n=0; while [ -n "$(cf "$_n" name)" ]; do _n=$((_n + 1)); done; echo "$_n"
}

show() {
    echo "current: host=$(cur_host) port=$(cur_port) mtu=$(cur_mtu)"
    _i=0; _N="$(n_candidates)"
    while [ "$_i" -lt "$_N" ]; do
        echo "  [$(cf "$_i" tier)] $(cf "$_i" name)  $(cf "$_i" endpoint)"
        _i=$((_i + 1))
    done
    echo "chosen: $(cat "$CHOSEN_FILE" 2>/dev/null || echo '?')  probe=$PROBE_URL relay_fallback=$RELAY_FALLBACK"
}

pin() {  # NAME
    _i=0; _N="$(n_candidates)"
    while [ "$_i" -lt "$_N" ]; do
        if [ "$(cf "$_i" name)" = "$1" ]; then
            _ep="$(cf "$_i" endpoint)"
            # we don't know the proper MTU here, fallback to 1280 or existing
            set_candidate "${_ep%%:*}" "${_ep##*:}" "$(cf "$_i" server_pubkey)"
            echo "$1" > "$CHOSEN_FILE"
            log "endpoint pinned -> $1 ($_ep)"
            return 0
        fi
        _i=$((_i + 1))
    done
    warn "pin: unknown candidate '$1'"; return 1
}

auto() {
    _uptime="$(cut -d. -f1 /proc/uptime 2>/dev/null || echo 99999)"
    if [ "$_uptime" -lt 60 ]; then
        log "delaying probe on boot"
        sleep 10
    fi
    _N="$(n_candidates)"
    [ "$_N" -gt 0 ] || { warn "no candidates in policy.json"; return 1; }
    _save_h="$(cur_host)"; _save_p="$(cur_port)"; _save_k="$(cur_pub)"; _save_m="$(cur_mtu)"
    _best_name=""; _best_ms=999999; _best_ep=""; _best_k=""; _best_mtu=""
    _relay_name=""; _relay_ep=""; _relay_k=""; _relay_tier=""
    _i=0
    while [ "$_i" -lt "$_N" ]; do
        _name="$(cf "$_i" name)"; _ep="$(cf "$_i" endpoint)"; _tier="$(cf "$_i" tier)"
        _k="$(cf "$_i" server_pubkey)"
        if [ "$_tier" = "2" ]; then           # remember the relay, test it last
            _relay_name="$_name"; _relay_ep="$_ep"; _relay_k="$_k"; _relay_tier="$_tier"; _i=$((_i + 1)); continue
        fi
        _res="$(probe "${_ep%%:*}" "${_ep##*:}" "$_k" "$_tier")"
        if [ -n "$_res" ]; then
            _ms="$(echo "$_res" | awk '{print $1}')"
            _mtu="$(echo "$_res" | awk '{print $2}')"
            log "probe $_name ($_ep) MTU $_mtu: ${_ms}ms"
            [ "$_ms" -lt "$_best_ms" ] && { _best_ms="$_ms"; _best_name="$_name"; _best_ep="$_ep"; _best_k="$_k"; _best_mtu="$_mtu"; }
        else
            log "probe $_name ($_ep): unreachable"
        fi
        _i=$((_i + 1))
    done
    # no direct worked — try the relay (last resort) if allowed
    if [ -z "$_best_name" ] && [ "$RELAY_FALLBACK" = "1" ] && [ -n "$_relay_ep" ]; then
        _res="$(probe "${_relay_ep%%:*}" "${_relay_ep##*:}" "$_relay_k" "$_relay_tier")"
        if [ -n "$_res" ]; then
            _ms="$(echo "$_res" | awk '{print $1}')"
            _mtu="$(echo "$_res" | awk '{print $2}')"
            log "all direct down — relay $_relay_name ($_relay_ep) MTU $_mtu: ${_ms}ms"
            _best_name="$_relay_name"; _best_ep="$_relay_ep"; _best_k="$_relay_k"; _best_ms="$_ms"; _best_mtu="$_mtu"
        fi
    fi
    if [ -n "$_best_name" ]; then
        set_candidate "${_best_ep%%:*}" "${_best_ep##*:}" "$_best_k" "$_best_mtu"
        echo "$_best_name" > "$CHOSEN_FILE"
        echo "$_best_mtu" > "$MTU_FILE"
        log "endpoint autoselected -> $_best_name ($_best_ep, MTU $_best_mtu, ${_best_ms}ms)"
        if [ "$_best_name" = "$_relay_name" ] && [ -z "${NO_RECOVER:-}" ]; then
            [ -f /var/run/wg-relay-recovery.pid ] && kill "$(cat /var/run/wg-relay-recovery.pid)" 2>/dev/null
            (
                echo $$ > /var/run/wg-relay-recovery.pid
                _attempts=0
                while [ "$_attempts" -lt 2 ]; do
                    sleep 60
                    _any_t1_up=0
                    _i=0; _N="$(n_candidates)"
                    while [ "$_i" -lt "$_N" ]; do
                        if [ "$(cf "$_i" tier)" = "1" ]; then
                            _ep="$(cf "$_i" endpoint)"
                            if ping -c 1 -W 2 "${_ep%%:*}" >/dev/null 2>&1; then
                                _any_t1_up=1
                                break
                            fi
                        fi
                        _i=$((_i + 1))
                    done
                    if [ "$_any_t1_up" = "1" ]; then
                        log "relay recovery: tier 1 is pingable, retrying auto"
                        NO_RECOVER=1 wg-split-endpoint --auto
                        if [ "$(cat "$CHOSEN_FILE" 2>/dev/null)" != "$_relay_name" ]; then
                            exit 0
                        fi
                        _attempts=$((_attempts + 1))
                    fi
                done
                log "relay recovery: gave up after 2 tests"
            ) &
        fi
        return 0
    fi
    # everything failed — restore where we started so we don't sit on a dead one
    warn "no candidate reachable — restoring $_save_h:$_save_p"
    set_candidate "$_save_h" "$_save_p" "$_save_k" "$_save_m"
    return 1
}

case "${1:-}" in
    --auto)  auto ;;
    --pin)   [ -n "${2:-}" ] || die "--pin needs a name"; pin "$2" ;;
    --show)  show ;;
    *) echo "usage: $0 --auto | --pin NAME | --show" >&2; exit 1 ;;
esac
