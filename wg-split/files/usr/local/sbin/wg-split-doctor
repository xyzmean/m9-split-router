#!/bin/sh
# wg-split-doctor — structured self-diagnosis: "what is broken and what to fix?"
#
#   wg-split-doctor          human-readable report (for SSH)
#   wg-split-doctor --json   machine-readable (consumed by the LuCI panel)
#
# Every check carries a severity:
#   OK       working as intended
#   WARN     suboptimal / stale, not breaking routing right now
#   FIXABLE  broken but self-heals on the next tick or via one named command
#   FAIL     broken, needs an operator decision (firewall/config)
# Exit code = worst severity (0 OK, 1 WARN, 2 FIXABLE, 3 FAIL) so scripts/CI gate.
#
# Almost every probe reuses a common.sh helper — this file is orchestration, not
# new diagnostic logic. No `set -u`: OpenWrt's config_* helpers aren't nounset-safe.

JSON=0; EVENTS=0
case "${1:-}" in --json) JSON=1 ;; --events) EVENTS=1 ;; esac

# ---- result accumulators ---------------------------------------------------
# checks: one record per line, tab-separated SEV<TAB>CATEGORY<TAB>MSG<TAB>FIX.
CHECKS=""; EP_JSON=""; LIST_JSON=""; WORST=0
_rank() { case "$1" in OK) echo 0;; WARN) echo 1;; FIXABLE) echo 2;; FAIL) echo 3;; *) echo 0;; esac; }
add() {  # SEV CATEGORY MSG [FIX]
    CHECKS="$CHECKS$1	$2	$3	${4:-}
"
    _r=$(_rank "$1"); [ "$_r" -gt "$WORST" ] && WORST="$_r"
}
json_esc() { printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'; }   # ponytail: fields are ASCII control text
file_age() { _m="$(stat -c %Y "$1" 2>/dev/null || date -r "$1" +%s 2>/dev/null)"; [ -n "$_m" ] && echo $(( $(date +%s) - _m )) || echo -1; }
STALE_AGE=172800   # 2 days — lists refresh daily at 04:xx, so older = a missed run

# ---- self-test (pure logic, no router): the one runnable check. Runs BEFORE
# sourcing common.sh so it works off-box (`WG_SPLIT_SELFTEST=1 wg-split-doctor`).
if [ "${WG_SPLIT_SELFTEST:-0}" = "1" ]; then
    [ "$(json_esc 'a"b\c')" = 'a\"b\\c' ] || { echo "json_esc FAIL"; exit 1; }
    [ "$(_rank FAIL)" -gt "$(_rank FIXABLE)" ] && [ "$(_rank FIXABLE)" -gt "$(_rank WARN)" ] \
        && [ "$(_rank WARN)" -gt "$(_rank OK)" ] || { echo "_rank order FAIL"; exit 1; }
    echo "selftest OK"; exit 0
fi

. /usr/local/lib/wg-split/common.sh

# ---- failover event timeline (design §4.3) ---------------------------------
# `wg-split-doctor --events` -> JSON array of the RAM ring buffer journal()
# writes, newest first. Consumed by the LuCI dashboard timeline.
if [ "$EVENTS" = 1 ]; then
    printf '['
    { [ -s "$EVENTS_FILE" ] && sed '1!G;h;$!d' "$EVENTS_FILE"; } \
    | { _first=1
        while IFS="$(printf '\t')" read -r _ts _kind _from _to _reason; do
            [ -n "$_ts" ] || continue
            [ "$_first" = 1 ] && _first=0 || printf ','
            printf '{"ts":%s,"kind":"%s","from":"%s","to":"%s","reason":"%s"}' \
                "$_ts" "$(json_esc "$_kind")" "$(json_esc "$_from")" "$(json_esc "$_to")" "$(json_esc "$_reason")"
        done; }
    printf ']\n'
    exit 0
fi

STATE="$(read_state)"; ACTIVE="$(active_iface)"; ORDERED="$(endpoints_by_priority)"
case "$STATE" in vpn:*) PATH_KIND=vpn;; killswitch) PATH_KIND=killswitch;; zapret) PATH_KIND=zapret;; *) PATH_KIND=wan;; esac

# ---- config sanity ---------------------------------------------------------
if [ -z "$ORDERED" ]; then
    add FAIL config "no failover tunnels configured" "add a tunnel under Services -> wg-split (Failover tunnels)"
fi
if [ -z "$LAN_CIDR" ]; then
    add FAIL config "LAN subnet not set or not detected on '$LAN_IFACE' — no policy chains, all LAN traffic exits WAN" "set the LAN subnet (CIDR) or fix the LAN interface in Services -> wg-split"
fi

# ---- per-endpoint ----------------------------------------------------------
# peer sections carrying this iface's route_allowed_ips (named + anonymous cfg).
_peers_of() { uci show network 2>/dev/null | sed -n "s/^network\.\([^.=]*\)=\(wireguard\|amneziawg\)_$1\$/\1/p"; }
rai_ok() { for _s in $(_peers_of "$1"); do [ "$(uci -q get "network.$_s.route_allowed_ips" 2>/dev/null)" = "0" ] || return 1; done; return 0; }
# priority of an iface, via common.sh's endpoint collector (emits "prio<TAB>iface").
prio_of() { config_foreach _collect_endpoint endpoint | awk -v i="$1" '$2==i{print $1; exit}'; }

LANZ="$(fw_lan_zone)"
for _if in $ORDERED; do
    _present=false; _hs=-1; _health=skip; _zone=""; _masq=false; _fwd=false; _rx=0; _tx=0
    if iface_present "$_if"; then
        _present=true
        # cumulative rx/tx bytes (UI derives live speed between polls); design §4.1
        _rxtx="$(ep_transfer "$_if")"; _rx="${_rxtx%% *}"; _tx="${_rxtx##* }"
        [ -n "$_rx" ] || _rx=0; [ -n "$_tx" ] || _tx=0
        # PASSIVE health only — the doctor never probes (that mutates routing and
        # must stay out of the read-only LuCI path). Derive from handshake age, a
        # pure `wg show` read: fresh = ok, stale = idle (not "failed" — we didn't
        # test it; the failover daemon is the authoritative prober). The active
        # path in the summary already names the daemon-confirmed live tunnel.
        _hs="$(ep_liveness "$_if")"
        if [ "$_hs" -lt 180 ] 2>/dev/null; then _health=ok; else _health=idle; fi
    elif [ -n "$(uci -q get "network.$_if" 2>/dev/null)" ]; then
        # configured in /etc/config/network but the kernel link is gone (stopped /
        # auto 0) — recoverable; failover brings candidates up with ifup.
        add FIXABLE endpoint "$_if: configured but down (no kernel link)" "failover will bring it up, or run: ifup $_if"
    else
        add FAIL endpoint "$_if: interface does not exist (not configured in /etc/config/network)" "create it under Network -> Interfaces, or remove it from wg-split"
    fi
    # route_allowed_ips is a UCI setting, independent of link state — check it
    # whenever the endpoint is configured, so a down endpoint can't be ifup'd with
    # route_allowed_ips=1 and hijack the main table before wg-split-apply fixes it.
    # (Truly-absent ifaces have no peer sections, so rai_ok is trivially clean.)
    rai_ok "$_if" || add FIXABLE endpoint "$_if: route_allowed_ips not 0 on a peer (would hijack main routes when brought up)" "run wg-split-apply (forces route_allowed_ips=0)"
    # firewall path (reuses fw_* helpers; these only warn — wg-split never edits fw)
    if _zone="$(fw_zone_of_net "$_if")"; then
        if _role="$(fw_zone_is_shared "$_zone")"; then
            # Endpoint shares the WAN/LAN zone. That zone may already carry masq +
            # LAN->WAN forwarding, so the masq/fwd probes below would read "healthy" —
            # but auto-fix REFUSES a shared zone (it can't add tunnel rules without
            # opening the whole WAN/LAN). Flag it instead of reporting a false OK.
            add FAIL firewall "$_if: is in the shared '$_zone' ($_role) firewall zone — auto-fix can't add tunnel masq/forwarding without opening the whole $_role zone" "give $_if its own firewall zone, then run: wg-split-firewall fix $_if"
        elif ! fw_zone_is_tunnel_only "$_zone"; then
            # Zone also holds non-tunnel networks. masq + LAN->zone fwd may already be
            # present (read "healthy"), but auto-fix REFUSES a mixed zone — and the
            # reverse zone->LAN it would otherwise add is withheld, so site-to-site
            # inbound stays rejected. Flag it as the real, manual remediation.
            add FAIL firewall "$_if: shares firewall zone '$_zone' with non-tunnel networks — auto-fix refuses to change a mixed zone's masq/forwarding/policy (site-to-site inbound stays rejected)" "give $_if its own firewall zone, then run: wg-split-firewall fix $_if"
        else
            if fw_zone_has_masq "$_zone"; then _masq=true; else
                add FAIL firewall "$_if: zone '$_zone' has masquerading disabled" "enable masq on firewall zone '$_zone'"
            fi
            fw_zone_has_mtu_fix "$_zone" || add FIXABLE firewall "$_if: MSS clamping (mtu_fix) disabled on zone '$_zone' — large packets stall on low-MTU tunnels" "wg-split-firewall fix $_if"
            fw_zone_policies_open "$_zone" || add FAIL firewall "$_if: zone '$_zone' has a non-ACCEPT input/output/forward policy — blocks router-originated probes and site-to-site/intra-zone traffic" "wg-split-firewall fix $_if"
            if [ -n "$LANZ" ]; then
                if fw_has_forwarding "$LANZ" "$_zone"; then _fwd=true; else
                    add FAIL firewall "$_if: no forwarding '$LANZ' -> '$_zone' (fw4 will REJECT LAN->tunnel)" "add firewall forwarding src='$LANZ' dest='$_zone'"
                fi
                # Zone is tunnel-only here, so the reverse zone->LAN forwarding is safe
                # and the fix always adds it. Site-to-site (vpn_cidr) needs it or fw4
                # REJECTs remote-INITIATED traffic to LAN; plain outbound replies ride
                # conntrack ESTABLISHED, so only demand it when vpn_cidr is set.
                if [ -n "$VPN_CIDRS" ] && ! fw_has_forwarding "$_zone" "$LANZ"; then
                    add FAIL firewall "$_if: no reverse forwarding '$_zone' -> '$LANZ' (fw4 will REJECT remote-initiated site-to-site traffic to LAN)" "wg-split-firewall fix $_if"
                fi
            fi
        fi
    elif _gz="$(fw_zone_glob_covering "$_if")"; then
        # Covered by a device-glob zone (e.g. 'wg+'); auto-create would overlap it.
        add WARN firewall "$_if: not in an explicit firewall zone but matched by zone '$_gz' via a device wildcard — verify it has masq + lan<->zone + zone->wan" "review firewall zone '$_gz' (auto-fix won't create an overlapping zone)"
    else
        add FAIL firewall "$_if: not in any firewall zone (fw4 will REJECT LAN->tunnel)" "add '$_if' to a firewall zone with masq=1"
    fi
    EP_JSON="$EP_JSON{\"iface\":\"$(json_esc "$_if")\",\"type\":\"$(json_esc "$(ep_type "$_if")")\",\"priority\":\"$(json_esc "$(prio_of "$_if")")\",\"present\":$_present,\"handshake_age\":$_hs,\"rx\":$_rx,\"tx\":$_tx,\"health\":\"$_health\",\"zone\":\"$(json_esc "$_zone")\",\"masq\":$_masq,\"forwarding\":$_fwd},"
done

# ---- routing / killswitch --------------------------------------------------
# Match the EXACT rules common_rules installs (priority + fwmark + lookup target),
# not just "a rule at prio 999/1000" — a stale/foreign rule at the same priority
# must not read as healthy. And inspect the table-200 DEFAULT route specifically
# (not any route that merely mentions the active iface).
T200="$(ip -4 route show table "$WG_TABLE" 2>/dev/null)"
T200DEF="$(ip -4 route show table "$WG_TABLE" default 2>/dev/null)"
has_rule "$ANTI_LOOP_PRIO:.*fwmark.*lookup main" || add FAIL routing "anti-loop ip rule (prio $ANTI_LOOP_PRIO, fwmark -> main) missing or malformed" "restart the service: /etc/init.d/wg-split restart"
case "$PATH_KIND" in
    vpn)
        has_rule "$WG_RULE_PRIO:.*fwmark.*lookup $WG_TABLE" || add FAIL routing "wg fwmark ip rule (prio $WG_RULE_PRIO -> table $WG_TABLE) missing or malformed while active path is VPN" "restart the service: /etc/init.d/wg-split restart"
        case "$T200DEF" in
            *blackhole*) add FAIL routing "table $WG_TABLE default is blackholed but state says VPN ($STATE)" "run wg-split-failover (one pass) or restart the service" ;;
            *"dev $ACTIVE"*) : ;;
            "") add FAIL routing "table $WG_TABLE has no default route while active path is VPN" "run wg-split-failover" ;;
            *) add WARN routing "table $WG_TABLE default route is not via active iface '$ACTIVE'" "run wg-split-failover" ;;
        esac ;;
    killswitch)
        # the blackhole only catches marked LAN traffic if the wg fwmark rule still
        # routes it into table 200; without the rule, marked traffic falls through
        # to main and leaks to WAN despite the blackhole.
        has_rule "$WG_RULE_PRIO:.*fwmark.*lookup $WG_TABLE" || add FAIL routing "killswitch active but wg fwmark ip rule (prio $WG_RULE_PRIO -> table $WG_TABLE) missing/malformed — marked traffic bypasses the blackhole to WAN" "restart the service: /etc/init.d/wg-split restart"
        case "$T200DEF" in *blackhole*) : ;; *) add FAIL routing "killswitch active but table $WG_TABLE default is not a blackhole (traffic may leak)" "run wg-split-failover" ;; esac ;;
    wan|zapret)
        if [ "$KILLSWITCH" = "1" ]; then
            add FAIL routing "killswitch is ON but active path is '$STATE' (policy traffic on WAN instead of blackholed)" "check why no tunnel is healthy; failover should blackhole under killswitch"
        fi
        [ -n "$T200" ] && add WARN routing "active path is WAN/zapret but table $WG_TABLE still holds routes" "stale; clears on next failover tick" ;;
esac

# ---- site-to-site VPN subnets (design §4.5) --------------------------------
# Each vpn_cidr is typically a remote peer's LAN that must ride the tunnel
# (site-to-site). The real failure to catch is "added a VPN subnet but never ran
# apply": the subnet is in UCI but not in the live nft VPN set, so its packets are
# never marked. A forced `ip route get … mark` CANNOT see that gap — it just shows
# where *already-marked* traffic goes, and table 200's default resolves through the
# active tunnel regardless. So we check the marking precondition directly:
#
#   1. set membership — in blocklist/split the ONLY thing that marks a vpn_cidr is
#      membership in the live VPN nft set (@VPN_SET). We test the network's address
#      against the interval set with `nft get element` (normalization-proof: a
#      contained host address matches the stored CIDR). `full` mode has a catch-all
#      mark rule, so membership isn't load-bearing there — skip step 1.
#   2. egress — once marked, traffic must leave via the ACTIVE tunnel, not WAN.
#
# Only meaningful while a VPN path is up; under WAN/zapret the routing checks above
# already name the real cause.
if [ "$PATH_KIND" = vpn ] && [ -n "$VPN_CIDRS" ] && [ -n "$ACTIVE" ]; then
    for _cidr in $(printf '%s' "$VPN_CIDRS" | tr ', ' '\n' | grep -v '^$'); do
        _addr="${_cidr%/*}"
        case "$_addr" in *.*.*.*) : ;; *) continue ;; esac
        if [ "$MODE" != full ] \
           && ! nft get element inet fw4 "$VPN_SET" "{ $_addr }" >/dev/null 2>&1; then
            add FIXABLE routing \
                "VPN subnet $_cidr (site-to-site) is missing from the live VPN set ($VPN_SET) — its traffic is never marked for the tunnel" \
                "run wg-split-apply (rebuilds the VPN set + routes)"
            continue
        fi
        _dev="$(ip -4 route get "$_addr" mark "$WG_MARK" 2>/dev/null \
            | sed -n 's/.* dev \([^ ]*\).*/\1/p' | head -1)"
        [ -n "$_dev" ] || continue
        [ "$_dev" = "$ACTIVE" ] || add FIXABLE routing \
            "VPN subnet $_cidr (site-to-site) not routed into the tunnel — marked traffic egresses '$_dev', not '$ACTIVE'" \
            "run wg-split-apply (rebuilds the VPN set + routes)"
    done
fi

# ---- lists -----------------------------------------------------------------
# In blocklist/split, the live RU_SET is unreferenced — ru's real job is feeding
# the nozapret bypass set, so report its FILE prefix count (its contribution),
# not the empty set (which made doctor show a working list as count:0 — N3). In
# full mode the live set IS load-bearing, so report that.
ru_count_for_mode() {  # MODE SET_COUNT FILE_COUNT
    if [ "$1" = full ]; then echo "${2:-0}"; else echo "${3:-0}"; fi
}
list_row() {  # NAME ENABLED COUNT MIN FILE AGE COUNTOK [FILECOUNT]
    LIST_JSON="$LIST_JSON{\"name\":\"$1\",\"enabled\":$2,\"count\":$3,\"min\":$4,\"file\":\"$(json_esc "$5")\",\"age\":$6,\"ok\":$7,\"file_count\":${8:--1}},"
}
# ipsum (VPN set) — failover self-heals it from IPSUM_NFT_FILE. Only blocklist mode
# wires @IPSUM_SET into routing (see wg-split-apply); in full/split the set is
# defined but unreferenced, so an empty/stale ipsum doesn't break routing — don't
# raise FIXABLE/WARN there (it would falsely show the whole box as degraded).
_age=-1; [ -s "$IPSUM_FILE" ] && _age="$(file_age "$IPSUM_FILE")"
if [ "$IPSUM_ENABLED" = 1 ]; then
    _c="$(set_count "$IPSUM_TABLE" "$IPSUM_SET")"; _ok=true
    if [ "$MODE" = blocklist ]; then
        [ "${_c:-0}" -ge "$IPSUM_MIN_COUNT" ] || { _ok=false; add FIXABLE lists "ipsum set has $_c entries (<$IPSUM_MIN_COUNT)" "wg-split-update-ipsum, or it reloads on the next failover tick"; }
        [ -s "$IPSUM_FILE" ] || add WARN lists "ipsum list file not yet downloaded ($IPSUM_FILE)" "wg-split-update-ipsum"
        [ "$_age" -gt "$STALE_AGE" ] 2>/dev/null && add WARN lists "ipsum list is stale ($((_age/86400))d old)" "wg-split-update-ipsum"
    fi
    _ifc=0; [ -s "$IPSUM_FILE" ] && _ifc="$(grep -cE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$' "$IPSUM_FILE" 2>/dev/null)"
    list_row ipsum true "${_c:-0}" "$IPSUM_MIN_COUNT" "$IPSUM_FILE" "$_age" "$_ok" "${_ifc:-0}"
else list_row ipsum false 0 "$IPSUM_MIN_COUNT" "$IPSUM_FILE" -1 true; fi
# ru/cn (direct list; live nft set only exists in full mode)
_age=-1; [ -s "$RU_FILE" ] && _age="$(file_age "$RU_FILE")"
if [ "$RU_ENABLED" = 1 ]; then
    _set="$(set_count "$RU_TABLE" "$RU_SET")"
    _rfc=0; [ -s "$RU_FILE" ] && _rfc="$(grep -cE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$' "$RU_FILE" 2>/dev/null)"
    _c="$(ru_count_for_mode "$MODE" "${_set:-0}" "${_rfc:-0}")"; _ok=true
    if [ "$MODE" = full ]; then
        [ "${_set:-0}" -ge "$RU_MIN_COUNT" ] || { _ok=false; add FIXABLE lists "ru/cn set has $_set entries (<$RU_MIN_COUNT)" "wg-split-update-ru, or it reloads on the next failover tick"; }
    fi
    [ -s "$RU_FILE" ] || add WARN lists "ru/cn list file not yet downloaded ($RU_FILE)" "wg-split-update-ru"
    [ "$_age" -gt "$STALE_AGE" ] 2>/dev/null && add WARN lists "ru/cn list is stale ($((_age/86400))d old)" "wg-split-update-ru"
    list_row ru true "${_c:-0}" "$RU_MIN_COUNT" "$RU_FILE" "$_age" "$_ok" "${_rfc:-0}"
else list_row ru false 0 "$RU_MIN_COUNT" "$RU_FILE" -1 true 0; fi

# ---- zapret + nozapret -----------------------------------------------------
if [ "$ZAPRET_ENABLED" = 1 ]; then
    if zapret_available; then
        if zapret_running; then
            _c="$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")"; _ok=true
            [ "${_c:-0}" -ge "$ZAPRET_NOZAPRET_MIN" ] || { _ok=false; add FIXABLE zapret "nozapret bypass set has $_c entries (<$ZAPRET_NOZAPRET_MIN)" "wg-split-failover rebuilds it; or check the ru/cn list"; }
            list_row nozapret true "${_c:-0}" "$ZAPRET_NOZAPRET_MIN" "" -1 "$_ok"
        else
            add FIXABLE zapret "zapret is installed but not running" "the failover loop starts it; or: $ZAPRET_INIT start"
            list_row nozapret true 0 "$ZAPRET_NOZAPRET_MIN" "" -1 false
        fi
    else
        add WARN zapret "zapret is enabled in wg-split but not installed (auto-skipped)" "install zapret, or disable it in Services -> wg-split"
        list_row nozapret false 0 "$ZAPRET_NOZAPRET_MIN" "" -1 true
    fi
fi

# ---- dnsmasq domain tagging ------------------------------------------------
# A configured download URL counts as "domains expected" even before the first
# fetch lands a file — otherwise a URL-only setup whose list hasn't downloaded yet
# would silently report no domain tagging at all.
[ -n "$VPN_DOMAINS_URL" ]    && [ ! -s "$DOMAINS_VPN_FILE" ]    && add FIXABLE dnsmasq "VPN domains URL set but the list is not downloaded yet ($DOMAINS_VPN_FILE)" "wg-split-update-domains"
[ -n "$IGNORE_DOMAINS_URL" ] && [ ! -s "$DOMAINS_IGNORE_FILE" ] && add FIXABLE dnsmasq "ignore/direct domains URL set but the list is not downloaded yet ($DOMAINS_IGNORE_FILE)" "wg-split-update-domains"
_have_domains=false
{ [ -n "$VPN_DOMAINS$DIRECT_DOMAINS$VPN_DOMAINS_URL$IGNORE_DOMAINS_URL" ] || [ -s "$DOMAINS_VPN_FILE" ] || [ -s "$DOMAINS_IGNORE_FILE" ]; } && _have_domains=true
if [ "$_have_domains" = true ]; then
    _dir="$(sed -n 's/^conf-dir=//p' /var/etc/dnsmasq.conf* 2>/dev/null | head -1)"
    [ -n "$_dir" ] || _dir="$(dirname "$DNSMASQ_NFTSET_FILE")"
    [ -s "$_dir/$(basename "$DNSMASQ_NFTSET_FILE")" ] \
        || add FIXABLE dnsmasq "domain tagging configured but the dnsmasq nftset drop-in is missing from $_dir" "run wg-split-apply (regenerates and reloads dnsmasq)"
fi

# ---- output ----------------------------------------------------------------
SEV_NAME() { case "$1" in 0) echo OK;; 1) echo WARN;; 2) echo FIXABLE;; 3) echo FAIL;; esac; }
OVERALL="$(SEV_NAME "$WORST")"

if [ "$JSON" = 1 ]; then
    printf '{"overall":"%s",' "$OVERALL"
    printf '"summary":{"mode":"%s","state":"%s","active_iface":"%s","killswitch":%s,"fail_count":%s,"lan_iface":"%s","lan_cidr":"%s"},' \
        "$(json_esc "$MODE")" "$(json_esc "$STATE")" "$(json_esc "$ACTIVE")" "${KILLSWITCH:-0}" "$(fail_get)" "$(json_esc "$LAN_IFACE")" "$(json_esc "$LAN_CIDR")"
    printf '"endpoints":[%s],' "${EP_JSON%,}"
    printf '"lists":[%s],' "${LIST_JSON%,}"
    printf '"checks":['
    _first=1
    printf '%s' "$CHECKS" | while IFS='	' read -r _s _cat _m _fix; do
        [ -n "$_s" ] || continue
        [ "$_first" = 1 ] && _first=0 || printf ','
        printf '{"severity":"%s","category":"%s","message":"%s","fix":"%s"}' \
            "$_s" "$(json_esc "$_cat")" "$(json_esc "$_m")" "$(json_esc "$_fix")"
    done
    printf ']}\n'
else
    echo "=== wg-split doctor ==="
    echo "overall : $OVERALL"
    echo "mode    : $MODE     state: ${STATE:-(none)}     active: ${ACTIVE:-(none)}"
    echo "killswitch: ${KILLSWITCH:-0}     fail_count: $(fail_get)     lan: $LAN_IFACE -> ${LAN_CIDR:-(none)}"
    echo
    printf '%s' "$CHECKS" | while IFS='	' read -r _s _cat _m _fix; do
        [ -n "$_s" ] || continue
        printf '[%-7s] %-8s %s\n' "$_s" "$_cat" "$_m"
        [ -n "$_fix" ] && printf '              -> fix: %s\n' "$_fix"
    done
    [ -z "$CHECKS" ] && echo "(no checks produced)"
    echo
    echo "exit: $WORST  (0 OK, 1 WARN, 2 FIXABLE, 3 FAIL)"
fi
exit "$WORST"
