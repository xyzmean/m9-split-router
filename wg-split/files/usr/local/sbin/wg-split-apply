#!/bin/sh
# wg-split-apply — regenerate the policy-derived layer from UCI (/etc/config/wg-split).
#
# Run by hand or after a config change (LuCI calls it on save). It is the only
# writer of:
#   /etc/nftables.d/30-wg-split.nft   (canonical ruleset, regenerated in place)
#   $DNSMASQ_NFTSET_FILE              (domain -> nftset lines for dnsmasq)
# then reloads fw4 + dnsmasq and re-runs the failover pass to (re)install routes.
#
# Marks/chains match the reference split: wg_split_endpoint_mark_prerouting @
# mangle (anti-loop), wg_split_ipsum_mark_prerouting @ mangle+1 (policy),
# device overrides @ mangle-2, force-direct @ mangle-1.
set -u
. /usr/local/lib/wg-split/common.sh

# Keep only bare IPv4 / IPv4-CIDR tokens — these go verbatim into the nft ruleset.
valid_cidr4() { grep -Ex '([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?'; }
clean_cidrs() { echo "$1" | tr ' ' '\n' | grep -v '^$' | valid_cidr4; }

VPN_CIDRS="$(clean_cidrs "$VPN_CIDRS")"
DIRECT_CIDRS="$(clean_cidrs "$DIRECT_CIDRS")"

# ---- endpoints must not self-route -----------------------------------------
# wg-split owns routing via marks + table 200. If a tunnel interface has
# route_allowed_ips=1 (the LuCI default for full-tunnel peers), `ifup` installs
# its AllowedIPs (often 0.0.0.0/0) into the MAIN table and hijacks WAN/direct
# traffic — including when we merely bring a candidate up to probe it. Force it
# off on every configured endpoint (idempotent; reload network only on change).
# OpenWrt's wireguard/amneziawg proto reads route_allowed_ips PER PEER (the
# `@wireguard_<iface>[N]` / `@amneziawg_<iface>[N]` sections), not off the
# interface — so clear it on every peer section (plus the iface, harmlessly).
_net_changed=0
_clear_rai() {
    [ "$(uci -q get "network.$1.route_allowed_ips")" = "0" ] && return
    uci -q set "network.$1.route_allowed_ips=0" && _net_changed=1
}
for _if in $(endpoints_by_priority); do
    _clear_rai "$_if"
    for _sec in $(uci show network 2>/dev/null \
            | sed -n "s/^network\.\(@\(wireguard\|amneziawg\)_${_if}\[[0-9]*\]\)=.*/\1/p"); do
        _clear_rai "$_sec"
    done
done
if [ "$_net_changed" = 1 ]; then
    uci -q commit network
    /etc/init.d/network reload >/dev/null 2>&1 || true
    log "forced route_allowed_ips=0 on endpoints (wg-split owns routing)"
fi

# ---- nft ruleset (canonical 30-wg-split.nft) -------------------------------
emit_set() {  # $1 set name, $2 size, stdin = cidrs
    _items="$(cat | tr '\n' ' ' | sed 's/  */, /g; s/^ *//; s/, *$//')"
    echo "set $1 {"
    echo "    type ipv4_addr; flags interval; auto-merge; size $2;"
    [ -n "$_items" ] && echo "    elements = { $_items }"
    echo "}"
}

# Anti-loop daddr: the IPs every configured tunnel actually connects to (so
# LAN->endpoint packets aren't themselves routed into a tunnel). Prefer the live
# kernel endpoint per iface; fall back to nothing if the tunnel is down.
EP_IPS=""
for _if in $(endpoints_by_priority); do
    EP_IPS="$EP_IPS $(wgshow "$_if" endpoints 2>/dev/null \
        | awk '{print $2}' | sed 's/:[0-9]*$//' | grep -E '^[0-9]+\.')"
done
ep_braces="$(echo "$EP_IPS" | tr ' ' '\n' | grep -E '^[0-9]' | sort -u | paste -sd, -)"

# Also true when only a downloaded domain list is configured — otherwise the
# VPN/direct sets (and the policy/direct chains) wouldn't be emitted, yet the
# dnsmasq loop below writes nftset directives pointing at those very sets.
HAS_VPN=0;    { [ -n "$VPN_CIDRS" ]    || [ -n "$VPN_DOMAINS" ]    || [ -s "$DOMAINS_VPN_FILE" ];    } && HAS_VPN=1
HAS_DIRECT=0; { [ -n "$DIRECT_CIDRS" ] || [ -n "$DIRECT_DOMAINS" ] || [ -s "$DOMAINS_IGNORE_FILE" ]; } && HAS_DIRECT=1
# In `full` mode the policy chain marks ALL unmarked LAN traffic to the VPN, so
# the downloaded ru/cn list must be carried as an explicit direct exception or it
# rides the tunnel. In blocklist/split it's direct by default (unmarked), so we
# only wire the RU set in full mode. update-ru fills RU_SET once it's defined.
RU_DIRECT=0; [ "$MODE" = "full" ] && [ "$RU_ENABLED" = 1 ] && RU_DIRECT=1

# Without a LAN subnet the saddr-matched chains would emit `ip saddr { }` and
# corrupt the table (fw4 reload fails -> policy dropped). Skip those chains but
# still define the sets, so the box stays safely all-WAN until lan_cidr is set.
LAN_OK=1; [ -n "$LAN_CIDR" ] || { LAN_OK=0; warn "lan_cidr not set — sets only, no policy chains"; }

# Per-device overrides from UCI 'device' sections -> nft lines (earliest chain).
emit_devices() {
    config_get _ip  "$1" ip   ''
    config_get _dm  "$1" mode ''
    echo "$_ip" | valid_cidr4 >/dev/null 2>&1 || { warn "skip device: bad ip '$_ip'"; return; }
    [ "$_dm" = "vpn" ]    && echo "    ip saddr $_ip meta mark set meta mark or $WG_MARK counter"
    [ "$_dm" = "direct" ] && echo "    ip saddr $_ip meta mark set meta mark or $ANTI_LOOP_MARK counter"
}
DEV_LINES="$(config_foreach emit_devices device)"

{
    echo "# wg-split — regenerated by wg-split-apply from UCI (mode $MODE). DO NOT EDIT."
    emit_set "$IPSUM_SET" 65536 </dev/null    # defined empty; filled live by updater/failover
    [ "$HAS_VPN" = 1 ]    && { echo "$VPN_CIDRS"    | emit_set "$VPN_SET" 4096; }
    [ "$HAS_DIRECT" = 1 ] && { echo "$DIRECT_CIDRS" | emit_set "$DIRECT_SET" 4096; }
    [ "$RU_DIRECT" = 1 ]  && emit_set "$RU_SET" 65536 </dev/null   # filled live by update-ru

    if [ -n "$DEV_LINES" ]; then
        echo "chain wg_split_device_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle - 2; policy accept;"
        echo "$DEV_LINES"
        echo "}"
    fi

    if { [ "$HAS_DIRECT" = 1 ] || [ "$RU_DIRECT" = 1 ]; } && [ "$LAN_OK" = 1 ]; then
        echo "chain wg_split_direct_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle - 1; policy accept;"
        [ "$HAS_DIRECT" = 1 ] && \
        echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$DIRECT_SET meta mark set meta mark or $ANTI_LOOP_MARK counter"
        [ "$RU_DIRECT" = 1 ] && \
        echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$RU_SET meta mark set meta mark or $ANTI_LOOP_MARK counter"
        echo "}"
    fi

    if [ -n "$ep_braces" ] && [ "$LAN_OK" = 1 ]; then
        echo "chain wg_split_endpoint_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle; policy accept;"
        echo "    ip saddr { $LAN_CIDR } ip daddr { $ep_braces } meta mark set meta mark or $ANTI_LOOP_MARK counter"
        echo "}"
    fi

    if [ "$LAN_OK" = 1 ]; then
        echo "chain wg_split_ipsum_mark_prerouting {"
        echo "    type filter hook prerouting priority mangle + 1; policy accept;"
        [ "$HAS_VPN" = 1 ] && \
        echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$VPN_SET meta mark set meta mark or $WG_MARK counter"
        case "$MODE" in
            blocklist)
                [ "$IPSUM_ENABLED" = "1" ] && \
                echo "    ip saddr { $LAN_CIDR } meta mark 0x0 ip daddr @$IPSUM_SET meta mark set meta mark or $WG_MARK counter" ;;
            full)
                echo "    ip saddr { $LAN_CIDR } meta mark 0x0 meta mark set meta mark or $WG_MARK counter" ;;
            split) : ;;
        esac
        echo "}"
    fi
} > "${POLICY_NFT_FILE}.tmp"
mv "${POLICY_NFT_FILE}.tmp" "$POLICY_NFT_FILE"

# ---- dnsmasq domain -> nftset (resolve-time tagging) -----------------------
# The live dnsmasq conf-dir wins (instanced builds use /tmp/dnsmasq.cfgXXXX.d).
DNSMASQ_DIR="$(sed -n 's/^conf-dir=//p' /var/etc/dnsmasq.conf* 2>/dev/null | head -1)"
[ -n "$DNSMASQ_DIR" ] || DNSMASQ_DIR="$(dirname "$DNSMASQ_NFTSET_FILE")"
mkdir -p "$DNSMASQ_DIR"
{
    echo "# Generated by wg-split-apply from UCI."
    # manual domains from UCI
    for d in $VPN_DOMAINS;    do echo "nftset=/$d/4#inet#fw4#$VPN_SET"; done
    for d in $DIRECT_DOMAINS; do echo "nftset=/$d/4#inet#fw4#$DIRECT_SET"; done
    # downloaded domain lists (one domain per line) written by wg-split-update-domains
    [ -r "$DOMAINS_VPN_FILE" ]    && while read -r d; do [ -n "$d" ] && echo "nftset=/$d/4#inet#fw4#$VPN_SET"; done    < "$DOMAINS_VPN_FILE"
    [ -r "$DOMAINS_IGNORE_FILE" ] && while read -r d; do [ -n "$d" ] && echo "nftset=/$d/4#inet#fw4#$DIRECT_SET"; done < "$DOMAINS_IGNORE_FILE"
} > "$DNSMASQ_DIR/$(basename "$DNSMASQ_NFTSET_FILE")"

# ---- reload + re-apply routing ---------------------------------------------
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
fw4 reload >/dev/null 2>&1 || /etc/init.d/firewall reload >/dev/null 2>&1 || true
# fw4 reload REPLACES `table inet fw4`, wiping the resolve-time set elements
# dnsmasq populated — restart dnsmasq again AFTER the reload so domain marks
# are re-established immediately.
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
[ -x /usr/local/sbin/wg-split-failover ] && /usr/local/sbin/wg-split-failover >/dev/null 2>&1 || true

log "applied: mode=$MODE ipsum=$IPSUM_ENABLED zapret=$ZAPRET_ENABLED kill=$KILLSWITCH vpn_cidrs=$(echo $VPN_CIDRS | wc -w) direct_cidrs=$(echo $DIRECT_CIDRS | wc -w)"
