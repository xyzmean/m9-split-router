#!/bin/sh
# wg-split-sync-nozapret — rebuild zapret's nozapret bypass set from:
#   ZAPRET_PRIVATES + RU file [+ IPSUM/VPN file]
#
# nozapret = IPs zapret must NOT touch. The VPN (ipsum) IPs are included while a
# tunnel is up (they're tunneled, so zapret should leave them alone). On full
# tunnel failure, wg-split-failover calls us with NOZAPRET_INCLUDE_VPN=0 so those
# IPs DROP OUT of nozapret and zapret DPI-bypasses them on WAN egress.
#
# Memory-safe: emits one compact `add element { x,y,z }` block, NOT per-line
# `add element { x }` (which on 240MB routers OOMs at ~38k+ entries).

set -e   # fail-fast on curl/validation; no `-u`, /lib/functions.sh isn't nounset-safe
. /usr/local/lib/wg-split/common.sh

# The nozapret set is rebuilt on EVERY failover tick (set_vpn -> rebuild_nozapret).
# When inputs haven't changed and the live set is healthy, that rebuild + its log
# line is pure churn (N1 log-flood / N2 CPU). nozapret_current decides "already
# current?": same signature AND live set >= min floor AND not force-requested.
# Pure logic (no nft/uci) so it is unit-tested off-box via tests/helper.bash.
nozapret_current() {   # NEW_SIG OLD_SIG LIVE_COUNT MIN FORCED
    [ "$5" = 1 ] && return 1                         # forced -> rebuild
    [ -n "$1" ] && [ "$1" = "$2" ] || return 1       # sig empty/changed -> rebuild
    [ "${3:-0}" -ge "${4:-0}" ] 2>/dev/null || return 1  # live set drained -> rebuild
    return 0
}

[ "$ZAPRET_ENABLED" = "1" ] || { log "zapret disabled (ZAPRET_ENABLED=0)"; exit 0; }
# An explicit caller (failover) sets NOZAPRET_INCLUDE_VPN. When unset (daily cron
# / ipsum-ru refresh cascade), derive it from the live state so a refresh while in
# the zapret/wan fallback doesn't re-add the VPN prefixes and silently disable the
# WAN DPI-bypass until the next failover tick.
if [ -n "${NOZAPRET_INCLUDE_VPN:-}" ]; then
    INCLUDE_VPN="$NOZAPRET_INCLUDE_VPN"
else
    case "$(read_state)" in
        zapret|wan) INCLUDE_VPN=0 ;;
        *)          INCLUDE_VPN=1 ;;
    esac
fi

TMP="/tmp/wg-split-sync-nozapret.$$"
NOZAPRET_SIG="/var/run/wg-split-nozapret.sig"
mkdir -p "$TMP"
trap 'rm -rf "$TMP"' EXIT INT TERM

{
    for p in $ZAPRET_PRIVATES; do echo "$p"; done
    [ -r "$RU_FILE" ] && cat "$RU_FILE" || true
    [ "$INCLUDE_VPN" = "1" ] && [ -r "$IPSUM_FILE" ] && cat "$IPSUM_FILE" || true
} | grep -E '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$' \
  | sort -u > "$TMP/all.lst"

count=$(wc -l < "$TMP/all.lst")
# The min-count floor guards the NORMAL set against a botched list refresh. In
# degradation mode (INCLUDE_VPN=0) we are deliberately shrinking the set to evict
# the VPN/ipsum prefixes so zapret DPI-bypasses them on WAN — aborting here would
# leave the previous (ipsum-laden) set in place and defeat the fallback, so the
# floor is enforced only when the VPN set is included.
if [ "$INCLUDE_VPN" = "1" ] && [ "$count" -lt "$ZAPRET_NOZAPRET_MIN" ]; then
    die "too few entries: $count (need $ZAPRET_NOZAPRET_MIN)"
fi

# N1/N2: skip the rebuild + log entirely when the candidate set is byte-identical
# to the last synced one AND the live set is still healthy. INCLUDE_VPN is part of
# the signature so the degradation toggle (1->0) always forces a rebuild.
NEW_SIG="$INCLUDE_VPN:$(md5sum < "$TMP/all.lst" | cut -d' ' -f1)"
OLD_SIG="$(cat "$NOZAPRET_SIG" 2>/dev/null)"
LIVE="$(set_count "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET")"
if nozapret_current "$NEW_SIG" "$OLD_SIG" "${LIVE:-0}" "$ZAPRET_NOZAPRET_MIN" "${WG_SPLIT_FORCE_SYNC:-0}"; then
    exit 0
fi

emit_nft_set_block "$ZAPRET_NOZAPRET_TABLE" "$ZAPRET_NOZAPRET_SET" < "$TMP/all.lst" > "$TMP/sync.nft"

nft -f "$TMP/sync.nft" || die "atomic nft sync failed (kept: $TMP/sync.nft)"
printf '%s\n' "$NEW_SIG" > "$NOZAPRET_SIG"
log "nozapret synced: $count entries"
