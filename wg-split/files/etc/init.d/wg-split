#!/bin/sh /etc/rc.common
# procd service for wg-split: regenerates the ruleset and runs the failover loop.
START=95
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/local/sbin/wg-split-failover --daemon
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

reload_service() {
    # The daemon sources UCI once at startup, so a config change (endpoints,
    # killswitch, health targets, mode, …) needs a restart to take effect — a
    # one-shot apply alone would leave the running daemon on the old options.
    # The daemon re-runs wg-split-apply on startup, so this also regenerates the
    # ruleset/routes.
    stop
    start
    # A changed list URL only takes effect on the next daily cron otherwise, so
    # refresh the lists now (background; the updaters validate + re-apply).
    # ponytail: unconditional refetch on apply — add per-URL change detection if
    # the re-download cost on every Save&Apply ever matters.
    ( /usr/local/sbin/wg-split-update-ipsum
      /usr/local/sbin/wg-split-update-ru
      /usr/local/sbin/wg-split-update-domains ) >/dev/null 2>&1 &
}

service_triggers() {
    procd_add_reload_trigger "wg-split"
}
